---
/*  Shell for the single-page site.

    The whole experience is one page: a grid of tiles with every project's
    writeup embedded and revealed in place (see index.astro + site.ts). No nav,
    no marquee, no router — clicking never navigates away. */
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = 'Portfolio of Raphael Murray-Browne — product designer.',
  image = '/images/exploration/lamp-corian.jpg',
} = Astro.props;

// Absolute URLs for link-preview cards (Astro.site = https://tremayah.com).
const canonical = new URL(Astro.url.pathname, Astro.site);
const ogImage = new URL(image, Astro.site);
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="theme-color" content="#fafafa" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="canonical" href={canonical} />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  {/* Open Graph / Twitter — the card shown when the link is shared (LinkedIn,
      WhatsApp, Slack, etc.). */}
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Raphael Murray-Browne" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:image" content={ogImage} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImage} />
  <!-- Warm the font host's connection (once for the CSS, once CORS for the
       font files themselves) before the render-blocking kit CSS is requested. -->
  <link rel="preconnect" href="https://use.typekit.net" />
  <link rel="preconnect" href="https://use.typekit.net" crossorigin />
  <link rel="stylesheet" href="https://use.typekit.net/var1bvf.css" />
</head>
<body class="landing-page">
  <slot />
  <script>
    import '../scripts/site.ts';
  </script>
</body>
</html>
