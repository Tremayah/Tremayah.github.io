---
/*  Minimal shell for the landing page only.

    Deliberately has no nav and no marquee — the landing is a clean image grid.
    When the visitor clicks through to a project, that page uses SiteLayout,
    whose nav slides in from the left. Shares <ClientRouter /> with SiteLayout
    so navigation between the two is a seamless, no-reload view transition. */
import { ClientRouter } from 'astro:transitions';
import DevTools from '../components/DevTools.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Portfolio of Raphael Murray-Browne — product designer.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="https://use.typekit.net/var1bvf.css" />
  <ClientRouter fallback="swap" />
</head>
<body class="landing-page">
  <slot />
  <DevTools />
  <script>
    import '../scripts/site.ts';
  </script>
</body>
</html>
