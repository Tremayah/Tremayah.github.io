---
/*  The persistent site shell shared by every page.

    Columns 1 (nav) and 4 (marquee), the lightbox, and the dev tools live here
    and persist across navigations. Only the <slot/> inside .content-col (column
    2) changes from page to page. <ClientRouter /> turns ordinary <a> links into
    instant, no-reload navigations with a working back button; combined with
    prefetching (astro.config) the target page is already in memory on click. */
import { ClientRouter } from 'astro:transitions';
import TitleNav from '../components/TitleNav.astro';
import Marquee from '../components/Marquee.astro';
import Lightbox from '../components/Lightbox.astro';
import DevTools from '../components/DevTools.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = 'Portfolio of Raphael Murray-Browne — product designer.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="https://use.typekit.net/var1bvf.css" />
  {/* fallback="swap": browsers without the View Transitions API still swap
      instantly (no simulated fade), matching the disabled animation on
      supporting browsers — so navigation is instant everywhere. */}
  <ClientRouter fallback="swap" />
</head>
<body>

  <div class="layout">
    <TitleNav />
    <main class="content-col">
      <slot />
    </main>
  </div>

  <Marquee />
  <Lightbox />
  <DevTools />

  <script>
    import '../scripts/site.ts';
  </script>
</body>
</html>
