---
/*  The whole single-page app: the 3×2 grid of tiles + every openable write-up
    embedded (hidden) + the "more works" grid below the fold. All behaviour lives
    in site.ts.

    `openId` (optional): when set (the /p/[slug] deep-link routes pass it), the
    stage carries data-open-initial so site.ts boots straight into that view —
    instantly, no fizzle. On "/" it's unset and the site opens on the home grid. */
import { getCollection, render } from 'astro:content';
import { OPENABLE_IDS } from '../openable';

interface Props {
  openId?: string | null;
}
const { openId = null } = Astro.props;

const all = await getCollection('projects');
const get = (id: string) => all.find((p) => p.id === id);

// Each openable tile + the CV page needs its write-up embedded (hidden), then
// revealed in place when opened. (Source of truth: src/openable.ts.)
const writeupIds = [...OPENABLE_IDS];
const writeups = (
  await Promise.all(
    writeupIds.map(async (id) => {
      const entry = get(id);
      if (!entry) return null;
      const { Content } = await render(entry);
      return { id, entry, Content };
    })
  )
).filter((w): w is NonNullable<typeof w> => w !== null);

const data = (id: string) => {
  const e = get(id);
  return { id, title: e?.data.title ?? id, cover: e?.data.cover, desc: e?.data.description ?? '' };
};

// Projects whose write-up is still a stub keep the "under construction"
// badge/notice; everything else is treated as finished (no badge). Removing an
// id from here is a status change (the project is genuinely done).
const UNDER_CONSTRUCTION = new Set(['topography-table']);
const isUC = (id: string): boolean => UNDER_CONSTRUCTION.has(id);

// A placeholder project tile (used by the "personal projects" view, real ones
// to come). `n` just numbers them.
const ph = (n: number) => ({
  kind: 'placeholder' as const,
  title: `project ${n}`,
  desc: 'Placeholder — a personal project will live here.',
});

// Cell 5 (the nav box) persists across views. The "personal projects" button
// swaps cells 0–4 between page 1 = the landing (contact card, projects, an
// about tile) and page 2 = the personal-projects set (Topography Table +
// placeholders — see site.ts setView). The contact card lives in cell 0 only on
// the landing; on page 2 that cell shows the Topography Table tile.
const cells = [
  { p1: { kind: 'name' },                               p2: { kind: 'photo', ...data('topography-table') } },
  { p1: { kind: 'photo', ...data('exploration') },      p2: ph(2) },
  { p1: { kind: 'photo', ...data('keycaps') },          p2: ph(3) },
  { p1: { kind: 'about' },                              p2: ph(4) },
  { p1: { kind: 'photo', ...data('table-tennis-bat') }, p2: ph(5) },
  { p1: { kind: 'nav' },                                p2: { kind: 'nav' } },
];

// "More works" tiles — revealed below the fold when the page is made scrollable.
// Real, openable projects first (Living Lamp, Smart Jewellery — the latter moved
// here when the landing's bottom-left cell became the about tile), then stub
// placeholders for projects not yet written up (Essays, Trebuchet). The grid
// flows into new rows automatically.
const moreWorks = [
  { kind: 'photo' as const, ...data('living-lamp') },
  { kind: 'photo' as const, ...data('progression') },
  { kind: 'placeholder' as const, title: 'Essays', desc: 'Written work — coming soon.' },
  { kind: 'placeholder' as const, title: 'Trebuchet', desc: 'A laser-cut plywood trebuchet — coming soon.' },
];

// FormSubmit alias — keeps the real address out of the page source (manage at formsubmit.co).
const FORMSUBMIT_ALIAS = '6d3f3fafc8f33af8dd86131575fc6736';
---

<div class="stage" data-page="1" data-open-initial={openId ?? undefined}>
  <ul class="landing-grid">
    {cells.map((cell) => (
      <li class="cell">
        {[cell.p1, cell.p2].map((t, i) => {
          const page = i + 1;
          if (t.kind === 'name') {
            // Not a <button> — it holds real form controls, which can't legally
            // nest inside an interactive element. The name + blurb are click
            // targets (data-focus-message) that jump focus into the message
            // box. The send button lives INSIDE the message box and doubles as
            // the status display. (Lives in cell 0 on the landing only.)
            return (
              <div class="tile tile--contact" data-page={page}>
                <div class="contact-card">
                  <div class="contact-head">
                    <h1 class="contact-name" data-focus-message>
                      <span>Raphael</span>
                      <span>Murray</span>
                      <span>Browne</span>
                    </h1>
                    <div class="contact-blurb" data-focus-message>
                      <p>Third year Product and Furniture Design student at University of Plymouth, UK.</p>
                      <p>Come check out my works, and drop me a message below (no details required).</p>
                    </div>
                  </div>
                  <form
                    class="contact-form"
                    data-contact-form
                    action={`https://formsubmit.co/ajax/${FORMSUBMIT_ALIAS}`}
                    method="POST"
                  >
                    <input type="hidden" name="_subject" value="New message — portfolio (tremayah.com)" />
                    <input type="hidden" name="_template" value="basic" />
                    <input
                      class="contact-honey"
                      type="text"
                      name="_honey"
                      tabindex={-1}
                      autocomplete="off"
                      aria-hidden="true"
                    />
                    <input
                      class="contact-email"
                      type="email"
                      name="email"
                      placeholder="Email address (optional)"
                      autocomplete="email"
                    />
                    <div class="contact-message-wrap">
                      <textarea class="contact-message" name="message" placeholder="Message" rows={3} required></textarea>
                      <button class="contact-submit" type="submit" data-state="idle">
                        <span class="contact-submit-label">send</span>
                        <span class="contact-submit-dots" aria-hidden="true"><i></i><i></i><i></i></span>
                      </button>
                    </div>
                  </form>
                </div>
              </div>
            );
          }
          if (t.kind === 'nav') {
            // The bottom-right cell: a 2×2 that persists. Top-left is a
            // description panel (filled on project hover — see site.ts);
            // top-right + bottom-left are section buttons; the bottom-right
            // is a links quad (its own 2×2 — see .nav-quad below).
            return (
              <div class="tile tile--nav tile--persist" data-page={page}>
                <div class="nav-corner">
                  <label class="anim-toggle" title="Toggle animations">
                    <input type="checkbox" class="anim-switch" data-anim-switch checked />
                    <span class="anim-toggle-box">animations</span>
                  </label>
                  <div class="nav-desc" data-desc-panel><span class="nav-desc-text"></span></div>
                </div>
                <button class="nav-box" type="button" data-action="view" data-view="2" data-desc="A collection of my personal design projects."><span class="nav-label">personal projects</span><span class="uc-badge uc-badge--small">under construction</span></button>
                <button class="nav-box nav-box--more" type="button" data-action="more" data-desc="Scroll down to see more of my work."><span class="nav-label">more works</span></button>
                {/* Links quad: Instagram, LinkedIn, the CV page, and one spare
                    slot (blank for now). Same red→blue treatment, smaller. */}
                <div class="nav-quad">
                  <a
                    class="nav-mini nav-mini--link"
                    href="https://www.instagram.com/rmb_is_designing/"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="Instagram — @rmb_is_designing"
                    title="Instagram"
                    data-desc="My Instagram — @rmb_is_designing."
                  >
                    <svg class="nav-mini-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                      <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z" />
                    </svg>
                  </a>
                  <a
                    class="nav-mini nav-mini--link"
                    href="https://www.linkedin.com/in/rmbdesign"
                    target="_blank"
                    rel="noopener noreferrer"
                    aria-label="LinkedIn — rmbdesign"
                    title="LinkedIn"
                    data-desc="My LinkedIn profile."
                  >
                    <svg class="nav-mini-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                      <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.225 0z" />
                    </svg>
                  </a>
                  <button class="nav-mini nav-mini--cv" type="button" data-action="cv" data-desc="My CV — education, skills, and experience."><span class="nav-mini-label">cv</span></button>
                  <div class="nav-mini nav-mini--blank" aria-hidden="true"></div>
                </div>
                {/* A gentle bobbing chevron in the caption band under the "more
                    works" box — a hint that the page scrolls to reveal more. */}
                <span class="more-chevron" aria-hidden="true">
                  <svg viewBox="0 0 24 12" focusable="false"><path d="M3 3 L12 10 L21 3" /></svg>
                </span>
              </div>
            );
          }
          if (t.kind === 'about') {
            // A short bio in the landing's bottom-left cell. Static (not
            // openable); hovering still feeds the description panel. Placeholder
            // copy — true to Raphael, for him to rewrite later.
            return (
              <div class="tile tile--about" data-page={page} data-desc="A little about who I am and what I do.">
                <div class="about-card">
                  <h2 class="about-head">about me</h2>
                  <div class="about-body">
                    <p>I'm Raphael — a third-year Product &amp; Furniture Design student at the University of Plymouth, on the hunt for a design-studio internship.</p>
                    <p>I like making real things: turning sketches into objects in wood, metal, ceramics and code, and picking up whatever skill each project demands. Off the clock — surfing in Cornwall, life drawing, and philosophy.</p>
                  </div>
                </div>
              </div>
            );
          }
          if (t.kind === 'placeholder') {
            // Placeholder project tile (personal-projects view). Inert for now;
            // hovering still feeds its blurb to the description panel.
            return (
              <div class="tile tile--placeholder" data-page={page} data-desc={t.desc}>
                <span class="uc-badge">under construction</span>
                <span class="placeholder-label">{t.title}</span>
              </div>
            );
          }
          // photo tile
          return (
            <button class="tile tile--photo" data-page={page} data-open={t.id} data-desc={t.desc} type="button">
              {isUC(t.id) && <span class="uc-badge">under construction</span>}
              <span class="tile-media">
                <img class="tile-img" src={t.cover} alt="" loading={page === 1 ? 'eager' : 'lazy'} decoding="async" />
              </span>
              <span class="tile-name">{t.title}</span>
            </button>
          );
        })}
      </li>
    ))}
  </ul>

  {/* Hidden writeups, revealed in place when a tile is opened. Each opens with
      a sticky scrolling-name bar at the top (the "home" control) that fizzles
      in as part of the page; the body wraps around the hero image below it. */}
  <div class="writeups">
    {writeups.map((w) => {
      const Body = w.Content;
      return (
        <article class="writeup" data-for={w.id} hidden>
          <div class="writeup-bar" data-home role="button" tabindex="0" aria-label="Back to home">
            <span class="writeup-bar-track" aria-hidden="true">
              {Array.from({ length: 14 }).map(() => (
                <span class="writeup-bar-item">Raphael Murray-Browne</span>
              ))}
            </span>
          </div>
          <div class="writeup-inner">
            {isUC(w.id) && <p class="uc-notice">under construction — this write-up is still being finished</p>}
            <h2 class="writeup-title">{w.entry.data.title}</h2>
            <p class="project-desc">{w.entry.data.description}</p>
            <div class="project-body"><Body /></div>
          </div>
        </article>
      );
    })}
  </div>
</div>

{/* "More works" — extra tiles below the fold. Scrolling the page down reveals
    them (and lights the "more works" toggle); the toggle is a shortcut to
    scroll there and back. Add more entries above and they flow into new rows. */}
<section class="more-grid" data-more-grid>
  {moreWorks.map((t) => (
    t.kind === 'photo' ? (
      <button class="more-tile more-tile--photo" type="button" data-open={t.id} data-desc={t.desc}>
        {isUC(t.id) && <span class="uc-badge">under construction</span>}
        <span class="tile-media">
          <img class="tile-img" src={t.cover} alt="" loading="lazy" decoding="async" />
        </span>
        <span class="tile-name">{t.title}</span>
      </button>
    ) : (
      <div class="more-tile" data-desc={t.desc}>
        <span class="uc-badge">under construction</span>
        <span class="placeholder-label">{t.title}</span>
      </div>
    )
  ))}
</section>
