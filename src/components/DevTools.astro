---
/*  Dev-only helpers: live font pickers + the landing drag/measure tool.
    Rendered ONLY under `npm run dev` (import.meta.env.DEV). In production this
    component outputs nothing, so it can never ship. Persisted so typed font
    values survive client-side navigation. */
---

{import.meta.env.DEV && (
  <div transition:persist="devtools">
    <div id="test-controls">
      <label>nav font<input type="text" id="pick-nav-font" placeholder="cofo-sans-pixel" /></label>
      <label>body font<input type="text" id="pick-body-font" placeholder="argent-pixel-cf" /></label>
      <label>drop cap font<input type="text" id="pick-dropcap-font" placeholder="lores-9-plus-narrow" /></label>
      <label>marquee font<input type="text" id="pick-marquee-font" placeholder="bitcount-mono-single-square" /></label>
    </div>
    <div id="drag-tool">
      <button id="drag-toggle">⠿ drag mode</button>
      <span id="drag-readout">off</span>
    </div>
  </div>
)}
