---
/*  Column 1 — the yellow title list.
    Real <a> links now (one page per destination). Persists across navigations
    via transition:persist, so its word-split animation is built only once and
    its scroll position is kept. The active link is marked server-side for first
    paint; site.ts keeps it in sync on subsequent client-side navigations. */
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects')).sort(
  (a, b) => (a.data.order ?? 99) - (b.data.order ?? 99)
);

const normalize = (p: string) => p.replace(/\/+$/, '') || '/';
const here = normalize(Astro.url.pathname);
const isActive = (href: string) => normalize(href) === here;

const links = [
  { href: '/about/', label: 'About' },
  { href: '/contact/', label: 'Contact' },
  ...projects.map((entry) => ({ href: `/${entry.id}/`, label: entry.data.title })),
];
---

<nav class="title-col" transition:persist="title-nav">
  {links.map(({ href, label }) => (
    <div class="item">
      <a
        class="item-trigger"
        href={href}
        data-astro-prefetch
        aria-current={isActive(href) ? 'page' : undefined}
      >
        <span class="item-name">{label}</span>
      </a>
    </div>
  ))}
</nav>
