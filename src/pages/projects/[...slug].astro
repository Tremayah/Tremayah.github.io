---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map(project => ({
    params: { slug: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
const { Content } = await render(project);

const { title, description, year, category, tags, image } = project.data;
---

<BaseLayout title={title} description={description}>
  <article class="project-page">
    <div class="container">

      <!-- Back link -->
      <a href="/projects" class="project-page__back">← Projects</a>

      <!-- Title -->
      <h1 class="project-page__title">{title}</h1>

      <!-- Meta bar -->
      <div class="project-page__meta">
        <span class="project-page__meta-item project-page__meta-item--accent">
          {year}
        </span>
        <span class="project-page__meta-sep">/</span>
        <span class="project-page__meta-item">{category}</span>
        {tags && tags.length > 0 && (
          <>
            <span class="project-page__meta-sep">/</span>
            {tags.map((tag, i) => (
              <>
                <span class="project-page__meta-item">{tag}</span>
                {i < tags.length - 1 && (
                  <span class="project-page__meta-sep">·</span>
                )}
              </>
            ))}
          </>
        )}
      </div>

      <!-- Hero image (if provided) -->
      {image && (
        <img
          src={image}
          alt={title}
          class="project-page__image"
          loading="lazy"
        />
      )}

      <!-- Markdown body -->
      <div class="project-page__body">
        <Content />
      </div>

    </div>
  </article>
</BaseLayout>
