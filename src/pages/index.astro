---
/*  "/" — the whole site.

    A single-page experience: a 3x2 grid of tiles that fills the viewport.
    Clicking a project tile keeps it in place, dissolves the other five with a
    pixel animation, and reveals that project's writeup in the freed space.

    The bottom-right cell is a 2x2 nav box that persists across views:
      • a description panel (top-left) — shows the hovered project's blurb
      • personal projects (top-right) — radial-fizzles to a set of project tiles
      • cv (bottom-left)              — fizzles to a full-page CV (nav box stays)
      • more works (bottom-right)     — makes the page scroll to reveal more tiles
    All behaviour lives in site.ts. */
import LandingLayout from '../layouts/LandingLayout.astro';
import { getCollection, render } from 'astro:content';

const all = await getCollection('projects');
const get = (id: string) => all.find((p) => p.id === id);

// Only the openable tiles + the CV page need their writeup embedded (hidden).
// (Essays etc. stay on disk for later — see src/content/projects.)
const writeupIds = [
  'exploration', 'keycaps', 'progression', 'table-tennis-bat', // landing projects
  'cv',                                                        // CV button → full page
];
const writeups = (
  await Promise.all(
    writeupIds.map(async (id) => {
      const entry = get(id);
      if (!entry) return null;
      const { Content } = await render(entry);
      return { id, entry, Content };
    })
  )
).filter((w): w is NonNullable<typeof w> => w !== null);

const data = (id: string) => {
  const e = get(id);
  return { id, title: e?.data.title ?? id, cover: e?.data.cover, desc: e?.data.description ?? '' };
};

// A placeholder project tile (used by the "personal projects" view, real ones
// to come). `n` just numbers them.
const ph = (n: number) => ({
  kind: 'placeholder' as const,
  title: `project ${n}`,
  desc: 'Placeholder — a personal project will live here.',
});

// Cell 5 (the nav box) persists across views. The "personal projects" button
// swaps cells 0–4 between page 1 = the landing (contact + four projects) and
// page 2 = a set of placeholder project tiles (see site.ts setView). The
// contact card lives in cell 0 only on the landing.
const cells = [
  { p1: { kind: 'name' },                               p2: ph(1) },
  { p1: { kind: 'photo', ...data('exploration') },      p2: ph(2) },
  { p1: { kind: 'photo', ...data('keycaps') },          p2: ph(3) },
  { p1: { kind: 'photo', ...data('progression') },      p2: ph(4) },
  { p1: { kind: 'photo', ...data('table-tennis-bat') }, p2: ph(5) },
  { p1: { kind: 'nav' },                                p2: { kind: 'nav' } },
];

// "More works" tiles — revealed below the fold when the page is made scrollable.
// Add as many as you like; the grid flows into new rows automatically.
const moreWorks = Array.from({ length: 6 }, (_, i) => ({
  title: `project ${i + 6}`,
  desc: 'Placeholder — more work to come.',
}));

const CONTACT_EMAIL = 'raphael.murraybrowne@gmail.com';
---

<LandingLayout title="Raphael Murray-Browne">
  <div class="stage" data-page="1">
    <ul class="landing-grid">
      {cells.map((cell) => (
        <li class="cell">
          {[cell.p1, cell.p2].map((t, i) => {
            const page = i + 1;
            if (t.kind === 'name') {
              // Not a <button> — it holds real form controls, which can't legally
              // nest inside an interactive element. The name + blurb are click
              // targets (data-focus-message) that jump focus into the message
              // box. The send button lives INSIDE the message box and doubles as
              // the status display. (Lives in cell 0 on the landing only.)
              return (
                <div class="tile tile--contact" data-page={page}>
                  <div class="contact-card">
                    <div class="contact-head">
                      <h1 class="contact-name" data-focus-message>
                        <span>Raphael</span>
                        <span>Murray</span>
                        <span>Browne</span>
                      </h1>
                      <div class="contact-blurb" data-focus-message>
                        <p>Third year Product and Furniture Design student at University of Plymouth, UK.</p>
                        <p>Come check out my works, and drop me a message below (no details required).</p>
                      </div>
                    </div>
                    <form
                      class="contact-form"
                      data-contact-form
                      action={`https://formsubmit.co/ajax/${CONTACT_EMAIL}`}
                      method="POST"
                    >
                      <input type="hidden" name="_subject" value="New message — portfolio (tremayah.com)" />
                      <input type="hidden" name="_template" value="basic" />
                      <input
                        class="contact-honey"
                        type="text"
                        name="_honey"
                        tabindex={-1}
                        autocomplete="off"
                        aria-hidden="true"
                      />
                      <input
                        class="contact-email"
                        type="email"
                        name="email"
                        placeholder="Email address (optional)"
                        autocomplete="email"
                      />
                      <div class="contact-message-wrap">
                        <textarea class="contact-message" name="message" placeholder="Message" rows={3} required></textarea>
                        <button class="contact-submit" type="submit" data-state="idle">
                          <span class="contact-submit-label">send</span>
                          <span class="contact-submit-dots" aria-hidden="true"><i></i><i></i><i></i></span>
                        </button>
                      </div>
                    </form>
                  </div>
                </div>
              );
            }
            if (t.kind === 'nav') {
              // The bottom-right cell: a 2×2 that persists. Top-left is a
              // description panel (filled on project hover — see site.ts);
              // the other three are section buttons.
              return (
                <div class="tile tile--nav tile--persist" data-page={page}>
                  <div class="nav-corner">
                    <label class="anim-toggle" title="Toggle animations">
                      <input type="checkbox" class="anim-switch" data-anim-switch checked />
                      <span class="anim-toggle-box">animations</span>
                    </label>
                    <div class="nav-desc" data-desc-panel><span class="nav-desc-text"></span></div>
                  </div>
                  <button class="nav-box" type="button" data-action="view" data-view="2" data-desc="A collection of my personal design projects."><span class="nav-label">personal projects</span><span class="uc-badge uc-badge--small">under construction</span></button>
                  <button class="nav-box" type="button" data-action="cv" data-desc="My CV — education, skills, and experience."><span class="nav-label">cv</span><span class="uc-badge uc-badge--small">under construction</span></button>
                  <button class="nav-box nav-box--more" type="button" data-action="more" data-desc="Scroll down to see more of my work."><span class="nav-label">more works</span><span class="uc-badge uc-badge--small">under construction</span></button>
                </div>
              );
            }
            if (t.kind === 'placeholder') {
              // Placeholder project tile (personal-projects view). Inert for now;
              // hovering still feeds its blurb to the description panel.
              return (
                <div class="tile tile--placeholder" data-page={page} data-desc={t.desc}>
                  <span class="uc-badge">under construction</span>
                  <span class="placeholder-label">{t.title}</span>
                </div>
              );
            }
            // photo tile
            return (
              <button class="tile tile--photo" data-page={page} data-open={t.id} data-desc={t.desc} type="button">
                {t.id !== 'exploration' && <span class="uc-badge">under construction</span>}
                <span class="tile-media">
                  <img class="tile-img" src={t.cover} alt="" loading={page === 1 ? 'eager' : 'lazy'} decoding="async" />
                </span>
                <span class="tile-name">{t.title}</span>
              </button>
            );
          })}
        </li>
      ))}
    </ul>

    {/* Hidden writeups, revealed in place when a tile is opened. Each opens with
        a sticky scrolling-name bar at the top (the "home" control) that fizzles
        in as part of the page; the body wraps around the hero image below it. */}
    <div class="writeups">
      {writeups.map((w) => {
        const Body = w.Content;
        return (
          <article class="writeup" data-for={w.id} hidden>
            <div class="writeup-bar" data-home role="button" tabindex="0" aria-label="Back to home">
              <span class="writeup-bar-track" aria-hidden="true">
                {Array.from({ length: 14 }).map(() => (
                  <span class="writeup-bar-item">Raphael Murray-Browne</span>
                ))}
              </span>
            </div>
            <div class="writeup-inner">
              {w.id !== 'exploration' && <p class="uc-notice">under construction — this write-up is still being finished</p>}
              <h2 class="writeup-title">{w.entry.data.title}</h2>
              <p class="project-desc">{w.entry.data.description}</p>
              <div class="project-body"><Body /></div>
            </div>
          </article>
        );
      })}
    </div>
  </div>

  {/* "More works" — extra tiles below the fold. Scrolling the page down reveals
      them (and lights the "more works" toggle); the toggle is a shortcut to
      scroll there and back. Add more entries above and they flow into new rows. */}
  <section class="more-grid" data-more-grid>
    {moreWorks.map((t) => (
      <div class="more-tile" data-desc={t.desc}>
        <span class="uc-badge">under construction</span>
        <span class="placeholder-label">{t.title}</span>
      </div>
    ))}
  </section>
</LandingLayout>
