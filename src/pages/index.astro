---
/*  "/" — the whole site.

    A single-page experience: a 3x2 grid of tiles that fills the viewport (no
    scrolling). Clicking a tile keeps it in place, dissolves the other five with
    a pixel animation, and reveals that project's writeup in the freed space.
    The "more works" tile pages the other five tiles to a second set of projects.
    All behaviour lives in site.ts. */
import LandingLayout from '../layouts/LandingLayout.astro';
import { getCollection, render } from 'astro:content';

const all = await getCollection('projects');
const get = (id: string) => all.find((p) => p.id === id);

// Every clickable tile across both pages needs its writeup embedded (hidden).
// ('about' is no longer opened from a tile — that cell is now the contact card.)
const writeupIds = [
  'exploration', 'keycaps', 'progression', 'essays',
  'living-lamp', 'trebuchet', 'culture', 'creative-skills',
];
const writeups = (
  await Promise.all(
    writeupIds.map(async (id) => {
      const entry = get(id);
      if (!entry) return null;
      const { Content } = await render(entry);
      return { id, entry, Content };
    })
  )
).filter((w): w is NonNullable<typeof w> => w !== null);

const data = (id: string) => {
  const e = get(id);
  return { id, title: e?.data.title ?? id, cover: e?.data.cover, desc: e?.data.description ?? '' };
};

// Six cells, each holding a page-1 and a page-2 variant. Cell 0 (name/about)
// and cell 5 ("more works") persist unchanged across both pages — only cells
// 1–4 swap to a second set of projects.
const cells = [
  { p1: { kind: 'name' },                          p2: { kind: 'name' } },
  { p1: { kind: 'photo', ...data('exploration') }, p2: { kind: 'photo', ...data('living-lamp') } },
  { p1: { kind: 'photo', ...data('keycaps') },     p2: { kind: 'photo', ...data('trebuchet') } },
  { p1: { kind: 'photo', ...data('progression') }, p2: { kind: 'photo', ...data('culture') } },
  { p1: { kind: 'photo', ...data('essays') },      p2: { kind: 'photo', ...data('creative-skills') } },
  { p1: { kind: 'more' },                          p2: { kind: 'more' } },
];

const CONTACT_EMAIL = 'raphael.murraybrowne@gmail.com';
---

<LandingLayout title="Raphael Murray-Browne">
  <div class="stage" data-page="1">
    <ul class="landing-grid">
      {cells.map((cell) => (
        <li class="cell">
          {[cell.p1, cell.p2].map((t, i) => {
            const page = i + 1;
            if (t.kind === 'name') {
              // Not a <button> — it holds real form controls, which can't
              // legally nest inside an interactive element.
              return (
                <div class="tile tile--contact tile--persist" data-page={page}>
                  <div class="contact-card">
                    <div class="contact-head">
                      <h1 class="contact-name">
                        <span>Raphael</span>
                        <span>Murray</span>
                        <span>Browne</span>
                      </h1>
                      <div class="contact-blurb">
                        <p>Third year Product and Furniture Design student.</p>
                        <p>Come check out my works, and drop me a message below — no details required.</p>
                      </div>
                    </div>
                    <form
                      class="contact-form"
                      data-contact-form
                      action={`https://formsubmit.co/ajax/${CONTACT_EMAIL}`}
                      method="POST"
                    >
                      <input type="hidden" name="_subject" value="New message — raphaelmurraybrowne.com" />
                      <input type="hidden" name="_template" value="basic" />
                      <input
                        class="contact-honey"
                        type="text"
                        name="_honey"
                        tabindex={-1}
                        autocomplete="off"
                        aria-hidden="true"
                      />
                      <input
                        class="contact-email"
                        type="email"
                        name="email"
                        placeholder="Email address (optional)"
                        autocomplete="email"
                      />
                      <textarea class="contact-message" name="message" placeholder="Message" rows={3} required />
                      <div class="contact-foot">
                        <p class="contact-status" aria-live="polite"></p>
                        <button class="contact-submit" type="submit">send</button>
                      </div>
                    </form>
                  </div>
                </div>
              );
            }
            if (t.kind === 'more') {
              return (
                <button class="tile tile--text tile--persist tile--more" data-page={page} data-action="more" type="button">
                  <span class="tile-label">more works</span>
                </button>
              );
            }
            // photo tile
            return (
              <button class="tile tile--photo" data-page={page} data-open={t.id} type="button">
                <span class="tile-media">
                  <img class="tile-img" src={t.cover} alt="" loading="lazy" />
                  <span class="tile-overview"><span class="tile-overview-text">{t.desc}</span></span>
                </span>
                <span class="tile-name">{t.title}</span>
              </button>
            );
          })}
        </li>
      ))}
    </ul>

    {/* Hidden writeups, revealed in place when a tile is opened */}
    <div class="writeups">
      {writeups.map((w) => {
        const Body = w.Content;
        return (
          <article
            class="writeup"
            data-for={w.id}
            data-cover={w.entry.data.cover}
            data-title={w.entry.data.title}
            hidden
          >
            <p class="project-desc">{w.entry.data.description}</p>
            <div class="project-body"><Body /></div>
          </article>
        );
      })}
    </div>
  </div>
</LandingLayout>
