---
import { getCollection, render } from 'astro:content';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const projects = await Promise.all(
  sorted.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  })
);

// 4 copies = 2 showing + 2 identical looping behind = seamless scroll
const MARQUEE_COPIES = 4;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Portfolio of Raphael Murray-Browne — product designer." />
  <title>Raphael Murray-Browne</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@700&family=Noto+Sans:wght@300;400;700&display=swap" rel="stylesheet" />
</head>
<body>

<div class="layout">

  <!-- Left column: title list — scrolls independently -->
  <nav class="title-col">

    <div class="item" data-item="about">
      <button class="item-trigger" type="button" aria-expanded="false">
        <span class="item-name">About</span>
      </button>
    </div>

    <div class="item" data-item="contact">
      <button class="item-trigger" type="button" aria-expanded="false">
        <span class="item-name">Contact</span>
      </button>
    </div>

    {projects.map(({ entry }) => (
      <div class="item" data-item={entry.id}>
        <button class="item-trigger" type="button" aria-expanded="false">
          <span class="item-name">{entry.data.title}</span>
        </button>
      </div>
    ))}

  </nav>

  <!-- Middle column: content panels — scrolls independently -->
  <div class="content-col">

    <div class="item-panel" data-panel="about">
      <div class="prose-area">
        <p>Aspiring product designer; do you think I'm there yet?</p>
        <p>First-year work exploring electronics, materials, manufacturing, and the relationship between objects and the people who use them.</p>
      </div>
    </div>

    <div class="item-panel" data-panel="contact">
      <div class="prose-area">
        <a class="contact-link" href="mailto:raphael.murraybrowne@gmail.com">raphael.murraybrowne@gmail.com</a>
        <a class="contact-link" href="https://www.instagram.com/rmb_is_designing/" target="_blank" rel="noopener">↗ Instagram — RMB_IS_DESIGNING</a>
      </div>
    </div>

    {projects.map(({ entry, Content }) => (
      <div class="item-panel" data-panel={entry.id}>
        <div class="project-report">
          <p class="project-desc">{entry.data.description}</p>
          <div class="project-body">
            <Content />
          </div>
        </div>
      </div>
    ))}

  </div>

</div>

<!-- Fixed vertical marquee — right edge -->
<aside class="marquee-vert" aria-hidden="true">
  <div class="marquee-track">
    {Array.from({ length: MARQUEE_COPIES }).map(() => (
      <span class="marquee-item">RAPHAEL MURRAY BROWNE</span>
    ))}
  </div>
</aside>

</body>
</html>

<style is:global>
  :root {
    --fg:     #1c1c1c;
    --accent: #5200ff;
    --bg:     #ffffff;
    --mono:   'Space Mono', monospace;
    --sans:   'Noto Sans', system-ui, sans-serif;
    --col-w:  14rem;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    height: 100%;
    background: var(--bg);
    color: var(--fg);
    -webkit-font-smoothing: antialiased;
  }

  /* ── Three-column page layout ────────────── */
  .layout {
    display: flex;
    height: 100dvh;
    overflow: hidden;
    padding-right: var(--col-w); /* leave room for fixed marquee */
  }

  /* Left: title list — independent scroll */
  .title-col {
    flex-shrink: 0;
    height: 100%;
    overflow-y: auto;
    scrollbar-width: none;
    padding-top: 1rem;
    padding-bottom: 6rem;
    background: var(--accent);
  }
  .title-col::-webkit-scrollbar { display: none; }

  /* Middle: content fills remaining space — independent scroll */
  .content-col {
    flex: 1;
    min-width: 0; /* prevent flex overflow */
    height: 100%;
    overflow-y: auto;
    scrollbar-width: none;
    padding-top: 1rem;
    padding-bottom: 6rem;
  }
  .content-col::-webkit-scrollbar { display: none; }

  /* Panels — instant show/hide, zero delay */
  .item-panel { display: none; }
  .item-panel[data-open] { display: block; }

  /* ── Trigger — width is text only ───────── */
  .item-trigger {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem clamp(1rem, 4vw, 2.5rem);
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: var(--mono);
    color: #fff;
  }

  /* ── Item name ───────────────────────────── */
  .item-name {
    font-family: var(--mono);
    font-weight: 700;
    font-size: clamp(1.1rem, 2.2vw, 1.6rem);
    line-height: 1.1;
    color: inherit;
    text-transform: lowercase;
    transition: color 0.18s ease;
  }

  .item-trigger:hover .item-name { color: #c2fe0c; }
  .item[data-open] > .item-trigger .item-name { color: #c2fe0c; }

  /* ── Word-split structure (built by JS) ─── */
  .word-wrap {
    display: inline-block;
    position: relative;
    vertical-align: top;
  }

  .word-half {
    display: block;
    transition: transform 0.22s cubic-bezier(0.77, 0, 0.175, 1);
    will-change: transform;
  }

  /* Split at ~58% of element height ≈ halfway through the x-height of lowercase letters */
  .word-top { clip-path: inset(0 0 42% 0); }

  .word-bot {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    clip-path: inset(58% 0 0 0);
  }

  /* When project opens: bottom half shifts 2px right */
  .item[data-open] .word-bot { transform: translateX(2px); }

  /* ── About / Contact prose ───────────────── */
  .prose-area {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.75rem clamp(1rem, 4vw, 2.5rem) 1.5rem;
    max-width: 56ch;
  }
  .prose-area p {
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 400;
    line-height: 1.75;
  }
  .contact-link {
    display: block;
    font-family: var(--sans);
    font-size: 0.9rem;
    color: var(--fg);
    text-decoration: none;
    width: fit-content;
    border-bottom: 1px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }
  .contact-link:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  /* ── Project vertical report ─────────────── */
  .project-report {
    padding: 0.75rem clamp(1rem, 4vw, 2.5rem) 2rem;
    max-width: 680px;
  }

  .project-desc {
    font-family: var(--sans);
    font-weight: 700;
    font-size: 0.9rem;
    line-height: 1.7;
    margin-bottom: 1.75rem;
    color: var(--fg);
  }

  .project-body {
    font-family: var(--sans);
    font-size: 0.85rem;
    font-weight: 400;
    line-height: 1.9;
    color: #555;
  }
  .project-body p { margin-bottom: 1rem; }
  .project-body p:last-child { margin-bottom: 0; }

  .project-body h2 {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #c2fe0c;
    margin-top: 2rem;
    margin-bottom: 0.6rem;
  }
  .project-body h2:first-child { margin-top: 0; }

  .project-body h3 {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #c2fe0c;
    margin-top: 1.25rem;
    margin-bottom: 0.35rem;
  }
  .project-body ul, .project-body ol {
    padding-left: 1.1rem;
    margin-bottom: 1rem;
  }
  .project-body li { margin-bottom: 0.2rem; }
  .project-body a { color: var(--accent); text-decoration: underline; }
  .project-body strong { color: var(--fg); }
  .project-body em { font-style: italic; }

  .project-body img {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 1.25rem 0;
  }

  /* ── Vertical marquee ────────────────────── */
  .marquee-vert {
    position: fixed;
    top: 0;
    right: 0;
    width: var(--col-w);
    height: 100dvh;
    overflow: hidden;
    z-index: 10;
  }

  .marquee-track {
    display: flex;
    flex-direction: column;
    align-items: center;
    animation: march-down 140s linear infinite;
    will-change: transform;
  }

  /* rotate(180deg): letter bottoms face the window edge */
  .marquee-item {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-family: var(--sans);
    font-weight: 700;
    font-size: 14rem;
    line-height: 1;
    text-transform: uppercase;
    color: var(--fg);
    padding-block: 6rem;
    white-space: nowrap;
    user-select: none;
  }

  @keyframes march-down {
    from { transform: translateY(-50%); }
    to   { transform: translateY(0); }
  }
</style>

<script>
  // ── Build split-word structure in each item name ──────────────────────
  function buildSplitWords(nameEl) {
    const text = nameEl.textContent?.trim() ?? '';
    nameEl.textContent = '';
    text.split(' ').forEach((word, i, arr) => {
      const wrap = document.createElement('span');
      wrap.className = 'word-wrap';

      const top = document.createElement('span');
      top.className = 'word-half word-top';
      top.textContent = word;

      const bot = document.createElement('span');
      bot.className = 'word-half word-bot';
      bot.textContent = word;
      bot.setAttribute('aria-hidden', 'true');

      wrap.appendChild(top);
      wrap.appendChild(bot);
      nameEl.appendChild(wrap);

      if (i < arr.length - 1) {
        nameEl.appendChild(document.createTextNode(' '));
      }
    });
  }

  // ── Instant panel swap — no animation ────────────────────────────────
  const allItems  = Array.from(document.querySelectorAll('.item'));
  const allPanels = Array.from(document.querySelectorAll('.item-panel'));
  const contentCol = document.querySelector('.content-col');

  function toggle(item) {
    const id      = item.dataset.item;
    const wasOpen = item.hasAttribute('data-open');

    // Close all
    allItems.forEach(i => {
      i.removeAttribute('data-open');
      i.querySelector('.item-trigger')?.setAttribute('aria-expanded', 'false');
    });
    allPanels.forEach(p => p.removeAttribute('data-open'));

    if (!wasOpen) {
      item.setAttribute('data-open', '');
      item.querySelector('.item-trigger')?.setAttribute('aria-expanded', 'true');
      const panel = document.querySelector(`[data-panel="${id}"]`);
      if (panel) {
        panel.setAttribute('data-open', '');
        // Scroll content column back to top when switching panels
        contentCol?.scrollTo({ top: 0 });
      }
    }
  }

  // ── Marquee hover: snap to start, seamless resume on mouseleave ───────
  const marqueeVert  = document.querySelector('.marquee-vert');
  const marqueeTrack = document.querySelector('.marquee-track');

  if (marqueeVert && marqueeTrack) {
    marqueeVert.addEventListener('mouseenter', () => {
      const matrix   = new DOMMatrix(window.getComputedStyle(marqueeTrack).transform);
      const currentY = matrix.m42;

      // Freeze at current position, kill animation
      marqueeTrack.style.animation  = 'none';
      marqueeTrack.style.transform  = `translateY(${currentY}px)`;
      void marqueeTrack.offsetHeight;

      // Transition toward the animation's start position
      const startY = -(marqueeTrack.scrollHeight / 2);
      marqueeTrack.style.transition = 'transform 1s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
      marqueeTrack.style.transform  = `translateY(${startY}px)`;
    });

    marqueeVert.addEventListener('mouseleave', () => {
      // Read wherever the snap transition got to (may be mid-way)
      const matrix   = new DOMMatrix(window.getComputedStyle(marqueeTrack).transform);
      const currentY = matrix.m42;
      const halfH    = marqueeTrack.scrollHeight / 2;

      // Map currentY → equivalent elapsed time in the 140s cycle
      // Y(t) = -halfH + (t/140)*halfH  →  t = (currentY + halfH) * 140 / halfH
      const elapsed = (currentY + halfH) * 140 / halfH;
      const delay   = -((elapsed % 140 + 140) % 140); // keep in range, negate

      // Pin, kill transition
      marqueeTrack.style.transition = 'none';
      marqueeTrack.style.transform  = `translateY(${currentY}px)`;
      void marqueeTrack.offsetHeight;

      // Resume animation seamlessly from the current position
      marqueeTrack.style.animation  = `march-down 140s linear ${delay.toFixed(3)}s infinite`;
      void marqueeTrack.offsetHeight;
      marqueeTrack.style.transform  = ''; // hand control to animation
    });
  }

  // ── Init ──────────────────────────────────────────────────────────────
  allItems.forEach(item => {
    const btn    = item.querySelector('.item-trigger');
    const nameEl = item.querySelector('.item-name');
    if (!btn || !nameEl) return;

    buildSplitWords(nameEl);
    btn.addEventListener('click', () => toggle(item));
  });
</script>
