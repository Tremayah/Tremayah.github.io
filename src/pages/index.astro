---
import { getCollection, render } from 'astro:content';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const projects = await Promise.all(
  sorted.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  })
);

// 4 copies = 2 showing + 2 identical looping behind = seamless scroll
const MARQUEE_COPIES = 4;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Portfolio of Raphael Murray-Browne — product designer." />
  <title>Raphael Murray-Browne</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@700&family=Noto+Sans:wght@300;400;700&display=swap" rel="stylesheet" />
</head>
<body>

<div class="layout">

  <!-- Left column: title list — stays fixed while content changes -->
  <nav class="title-col">

    <div class="item" data-item="about">
      <button class="item-trigger" type="button" aria-expanded="false">
        <span class="item-name">About</span>
      </button>
    </div>

    <div class="item" data-item="contact">
      <button class="item-trigger" type="button" aria-expanded="false">
        <span class="item-name">Contact</span>
      </button>
    </div>

    {projects.map(({ entry }) => (
      <div class="item" data-item={entry.id}>
        <button class="item-trigger" type="button" aria-expanded="false">
          <span class="item-name">{entry.data.title}</span>
        </button>
      </div>
    ))}

  </nav>

  <!-- Middle column: content panels — instant show/hide, no animation -->
  <div class="content-col">

    <div class="item-panel" data-panel="about">
      <div class="prose-area">
        <p>Aspiring product designer; do you think I'm there yet?</p>
        <p>First-year work exploring electronics, materials, manufacturing, and the relationship between objects and the people who use them.</p>
      </div>
    </div>

    <div class="item-panel" data-panel="contact">
      <div class="prose-area">
        <a class="contact-link" href="mailto:raphael.murraybrowne@gmail.com">raphael.murraybrowne@gmail.com</a>
        <a class="contact-link" href="https://www.instagram.com/rmb_is_designing/" target="_blank" rel="noopener">↗ Instagram — RMB_IS_DESIGNING</a>
      </div>
    </div>

    {projects.map(({ entry, Content }) => (
      <div class="item-panel" data-panel={entry.id}>
        <div class="h-scroll">
          {entry.data.image && (
            <div class="h-block h-block--img">
              <img src={entry.data.image} alt={entry.data.title} loading="lazy" />
            </div>
          )}
          <div class="h-block h-block--text">
            <p class="project-desc">{entry.data.description}</p>
            <div class="project-body">
              <Content />
            </div>
          </div>
        </div>
      </div>
    ))}

  </div>

</div>

<!-- Fixed vertical marquee — right edge -->
<aside class="marquee-vert" aria-hidden="true">
  <div class="marquee-track">
    {Array.from({ length: MARQUEE_COPIES }).map(() => (
      <span class="marquee-item">RAPHAEL MURRAY BROWNE</span>
    ))}
  </div>
</aside>

</body>
</html>

<style is:global>
  :root {
    --fg:     #1c1c1c;
    --accent: #5200ff;
    --bg:     #ffffff;
    --mono:   'Space Mono', monospace;
    --sans:   'Noto Sans', system-ui, sans-serif;
    --col-w:  14rem;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    background: var(--bg);
    color: var(--fg);
    -webkit-font-smoothing: antialiased;
  }

  /* ── Three-column page layout ────────────── */
  .layout {
    display: flex;
    min-height: 100dvh;
    padding-right: var(--col-w); /* leave room for fixed marquee */
  }

  /* Left: title list — doesn't move when content opens */
  .title-col {
    flex-shrink: 0;
    padding-top: 1rem;
    padding-bottom: 6rem;
    background: var(--accent);
  }

  /* Middle: content fills remaining space */
  .content-col {
    flex: 1;
    min-width: 0; /* prevent flex overflow */
    padding-top: 1rem;
    padding-bottom: 6rem;
  }

  /* Panels — instant show/hide, zero delay */
  .item-panel { display: none; }
  .item-panel[data-open] { display: block; }

  /* ── Trigger — width is text only ───────── */
  .item-trigger {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem clamp(1rem, 4vw, 2.5rem);
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: var(--mono);
    color: #fff;
  }

  /* ── Item name ───────────────────────────── */
  .item-name {
    font-family: var(--mono);
    font-weight: 700;
    font-size: clamp(1.1rem, 2.2vw, 1.6rem);
    line-height: 1.1;
    color: inherit;
    text-transform: lowercase;
    transition: color 0.18s ease;
  }

  .item-trigger:hover .item-name { color: #c2fe0c; }
  .item[data-open] > .item-trigger .item-name { color: #c2fe0c; }

  /* ── Word-split structure (built by JS) ─── */
  .word-wrap {
    display: inline-block;
    position: relative;
    vertical-align: top;
  }

  .word-half {
    display: block;
    transition: transform 0.22s cubic-bezier(0.77, 0, 0.175, 1);
    will-change: transform;
  }

  /* Split at ~58% of element height ≈ halfway through the x-height of lowercase letters */
  .word-top { clip-path: inset(0 0 42% 0); }

  .word-bot {
    position: absolute;
    top: 0; left: 0;
    width: 100%;
    clip-path: inset(58% 0 0 0);
  }

  /* When project opens: bottom half shifts 2px right */
  .item[data-open] .word-bot { transform: translateX(2px); }

  /* ── About / Contact prose ───────────────── */
  .prose-area {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.75rem clamp(1rem, 4vw, 2.5rem) 1.5rem;
    max-width: 56ch;
  }
  .prose-area p {
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 400;
    line-height: 1.75;
  }
  .contact-link {
    display: block;
    font-family: var(--sans);
    font-size: 0.9rem;
    color: var(--fg);
    text-decoration: none;
    width: fit-content;
    border-bottom: 1px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }
  .contact-link:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  /* ── Horizontal scroll area ──────────────── */
  .h-scroll {
    display: flex;
    gap: 0;
    overflow-x: auto;
    padding: 1.25rem 0 1.75rem;
    align-items: flex-start;
    cursor: grab;
    scrollbar-width: none;
  }
  .h-scroll::-webkit-scrollbar { display: none; }
  .h-scroll:active { cursor: grabbing; }

  .h-block { flex-shrink: 0; }

  .h-block--img img {
    display: block;
    height: min(52vh, 460px);
    width: auto;
    max-width: 70vw;
    object-fit: contain;
    padding: 0 clamp(1rem, 4vw, 2.5rem);
  }

  .h-block--text {
    width: clamp(280px, 35vw, 440px);
    padding: 0 clamp(1rem, 4vw, 2.5rem);
    border-right: 1px solid #e8e8e8;
  }
  .h-block--text:last-child { border-right: none; }

  .project-desc {
    font-family: var(--sans);
    font-weight: 700;
    font-size: 0.82rem;
    line-height: 1.6;
    margin-bottom: 1.1rem;
    color: var(--fg);
  }

  .project-body {
    font-family: var(--sans);
    font-size: 0.78rem;
    font-weight: 400;
    line-height: 1.9;
    color: #555;
  }
  .project-body p { margin-bottom: 0.8rem; }
  .project-body p:last-child { margin-bottom: 0; }

  .project-body h2 {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #c2fe0c;
    margin-bottom: 0.5rem;
  }
  .project-body h3 {
    font-family: var(--mono);
    font-weight: 700;
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #c2fe0c;
    margin-top: 0.75rem;
    margin-bottom: 0.3rem;
  }
  .project-body ul, .project-body ol {
    padding-left: 1.1rem;
    margin-bottom: 0.8rem;
  }
  .project-body li { margin-bottom: 0.15rem; }
  .project-body a { color: var(--accent); text-decoration: underline; }
  .project-body strong { color: var(--fg); }
  .project-body em { font-style: italic; }

  .project-body img {
    max-width: 100%;
    height: auto;
    display: block;
    margin: 0.75rem 0;
  }

  /* ── Vertical marquee ────────────────────── */
  .marquee-vert {
    position: fixed;
    top: 0;
    right: 0;
    width: var(--col-w);
    height: 100dvh;
    overflow: hidden;
    z-index: 10;
  }

  .marquee-track {
    display: flex;
    flex-direction: column;
    align-items: center;
    animation: march-down 140s linear infinite;
    will-change: transform;
  }

  /* rotate(180deg): letter bottoms face the window edge */
  .marquee-item {
    writing-mode: vertical-rl;
    transform: rotate(180deg);
    font-family: var(--sans);
    font-weight: 700;
    font-size: 14rem;
    line-height: 1;
    text-transform: uppercase;
    color: var(--fg);
    padding-block: 6rem;
    white-space: nowrap;
    user-select: none;
  }

  @keyframes march-down {
    from { transform: translateY(-50%); }
    to   { transform: translateY(0); }
  }

  /* ── Card extended report ────────────────── */
  .card-extended {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .card-extended.expanded { max-height: 1200px; }
  .card-extended-inner {
    padding-top: 1.25rem;
    border-top: 1px solid #e8e8e8;
    margin-top: 1.25rem;
  }
  .card-ext-label {
    font-family: var(--mono);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #c2fe0c;
    margin-bottom: 0.75rem;
  }
  .card-ext-para {
    font-family: var(--sans);
    font-size: 0.75rem;
    font-weight: 400;
    line-height: 1.85;
    color: #666;
    margin-bottom: 0.75rem;
  }
  .card-ext-img {
    width: 100%;
    height: 130px;
    background: #f4f4f4;
    margin-top: 0.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .card-ext-img::after {
    content: '[ image ]';
    font-family: var(--mono);
    font-size: 0.6rem;
    color: #ccc;
    letter-spacing: 0.1em;
  }
</style>

<script>
  // ── Build split-word structure in each item name ──────────────────────
  function buildSplitWords(nameEl) {
    const text = nameEl.textContent?.trim() ?? '';
    nameEl.textContent = '';
    text.split(' ').forEach((word, i, arr) => {
      const wrap = document.createElement('span');
      wrap.className = 'word-wrap';

      const top = document.createElement('span');
      top.className = 'word-half word-top';
      top.textContent = word;

      const bot = document.createElement('span');
      bot.className = 'word-half word-bot';
      bot.textContent = word;
      bot.setAttribute('aria-hidden', 'true');

      wrap.appendChild(top);
      wrap.appendChild(bot);
      nameEl.appendChild(wrap);

      if (i < arr.length - 1) {
        nameEl.appendChild(document.createTextNode(' '));
      }
    });
  }

  // ── Instant panel swap — no animation ────────────────────────────────
  const allItems  = Array.from(document.querySelectorAll('.item'));
  const allPanels = Array.from(document.querySelectorAll('.item-panel'));

  function toggle(item) {
    const id      = item.dataset.item;
    const wasOpen = item.hasAttribute('data-open');

    // Close all
    allItems.forEach(i => {
      i.removeAttribute('data-open');
      i.querySelector('.item-trigger')?.setAttribute('aria-expanded', 'false');
    });
    allPanels.forEach(p => p.removeAttribute('data-open'));

    if (!wasOpen) {
      item.setAttribute('data-open', '');
      item.querySelector('.item-trigger')?.setAttribute('aria-expanded', 'true');
      const panel = document.querySelector(`[data-panel="${id}"]`);
      if (panel) panel.setAttribute('data-open', '');
    }
  }

  // ── Append an extended-report section to a card ───────────────────────
  function addExtendedSection(block) {
    const ext = document.createElement('div');
    ext.className = 'card-extended';
    const inner = document.createElement('div');
    inner.className = 'card-extended-inner';
    inner.innerHTML =
      '<p class="card-ext-label">Extended notes</p>' +
      '<p class="card-ext-para">Further detail on process decisions, material behaviour, and iterations made throughout the development of this project.</p>' +
      '<p class="card-ext-para">Documentation of key turning points and discoveries is ongoing — this section will be updated as the project develops.</p>' +
      '<div class="card-ext-img"></div>';
    ext.appendChild(inner);
    block.appendChild(ext);
  }

  // ── Split project body into horizontal cards by h2 heading ───────────
  function splitIntoCards(hscroll) {
    const textBlock = hscroll.querySelector('.h-block--text');
    if (!textBlock) return;
    const body = textBlock.querySelector('.project-body');
    if (!body) return;

    const children = Array.from(body.children);
    const sections = [];
    let current = [];

    children.forEach(el => {
      if (el.tagName === 'H2' && current.length > 0) {
        sections.push([...current]);
        current = [el];
      } else {
        current.push(el);
      }
    });
    if (current.length) sections.push(current);

    addExtendedSection(textBlock);
    if (sections.length <= 1) return;

    while (body.firstChild) body.removeChild(body.firstChild);
    sections[0].forEach(el => body.appendChild(el));

    for (let i = 1; i < sections.length; i++) {
      const block = document.createElement('div');
      block.className = 'h-block h-block--text';
      const newBody = document.createElement('div');
      newBody.className = 'project-body';
      sections[i].forEach(el => newBody.appendChild(el));
      block.appendChild(newBody);
      addExtendedSection(block);
      hscroll.appendChild(block);
    }
  }

  // ── Drag-to-scroll ────────────────────────────────────────────────────
  function addDragScroll(el) {
    let down = false, startX = 0, scrollL = 0, dragged = false;
    el.addEventListener('mousedown', e => {
      down = true;
      startX = e.pageX - el.offsetLeft;
      scrollL = el.scrollLeft;
      dragged = false;
    });
    el.addEventListener('mouseleave', () => { down = false; });
    el.addEventListener('mouseup',    () => { down = false; });
    el.addEventListener('mousemove',  e => {
      if (!down) return;
      e.preventDefault();
      if (Math.abs(e.pageX - el.offsetLeft - startX) > 5) dragged = true;
      el.scrollLeft = scrollL - (e.pageX - el.offsetLeft - startX) * 1.4;
    });
    el._wasDragged = () => dragged;
  }

  // ── Marquee hover: snap to start, seamless resume on mouseleave ───────
  const marqueeVert  = document.querySelector('.marquee-vert');
  const marqueeTrack = document.querySelector('.marquee-track');

  if (marqueeVert && marqueeTrack) {
    marqueeVert.addEventListener('mouseenter', () => {
      const matrix   = new DOMMatrix(window.getComputedStyle(marqueeTrack).transform);
      const currentY = matrix.m42;

      // Freeze at current position, kill animation
      marqueeTrack.style.animation  = 'none';
      marqueeTrack.style.transform  = `translateY(${currentY}px)`;
      void marqueeTrack.offsetHeight;

      // Transition toward the animation's start position
      const startY = -(marqueeTrack.scrollHeight / 2);
      marqueeTrack.style.transition = 'transform 1s cubic-bezier(0.25, 0.46, 0.45, 0.94)';
      marqueeTrack.style.transform  = `translateY(${startY}px)`;
    });

    marqueeVert.addEventListener('mouseleave', () => {
      // Read wherever the snap transition got to (may be mid-way)
      const matrix   = new DOMMatrix(window.getComputedStyle(marqueeTrack).transform);
      const currentY = matrix.m42;
      const halfH    = marqueeTrack.scrollHeight / 2;

      // Map currentY → equivalent elapsed time in the 140s cycle
      // Y(t) = -halfH + (t/140)*halfH  →  t = (currentY + halfH) * 140 / halfH
      const elapsed = (currentY + halfH) * 140 / halfH;
      const delay   = -((elapsed % 140 + 140) % 140); // keep in range, negate

      // Pin, kill transition
      marqueeTrack.style.transition = 'none';
      marqueeTrack.style.transform  = `translateY(${currentY}px)`;
      void marqueeTrack.offsetHeight;

      // Resume animation seamlessly from the current position
      marqueeTrack.style.animation  = `march-down 140s linear ${delay.toFixed(3)}s infinite`;
      void marqueeTrack.offsetHeight;
      marqueeTrack.style.transform  = ''; // hand control to animation
    });
  }

  // ── Init ──────────────────────────────────────────────────────────────
  allItems.forEach(item => {
    const btn    = item.querySelector('.item-trigger');
    const nameEl = item.querySelector('.item-name');
    if (!btn || !nameEl) return;

    buildSplitWords(nameEl);
    btn.addEventListener('click', () => toggle(item));
  });

  document.querySelectorAll('.h-scroll').forEach(el => {
    splitIntoCards(el);
    addDragScroll(el);

    // Scroll to end → expand all card-extended sections
    el.addEventListener('scroll', () => {
      const atEnd = el.scrollLeft + el.clientWidth >= el.scrollWidth - 20;
      if (atEnd) {
        el.querySelectorAll('.card-extended').forEach(ext => ext.classList.add('expanded'));
      }
    });

    // Click on a card → expand its extended section
    el.querySelectorAll('.h-block--text').forEach(card => {
      card.addEventListener('click', () => {
        if (el._wasDragged && el._wasDragged()) return;
        const ext = card.querySelector('.card-extended');
        if (ext) ext.classList.add('expanded');
      });
    });
  });
</script>
