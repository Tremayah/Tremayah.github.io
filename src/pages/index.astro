---
/*  "/" — the whole site.

    A single-page experience: a 3x2 grid of tiles that fills the viewport (no
    scrolling). Clicking a tile keeps it in place, dissolves the other five with
    a pixel animation, and reveals that project's writeup in the freed space.
    The "more works" tile pages the other five tiles to a second set of projects.
    All behaviour lives in site.ts. */
import LandingLayout from '../layouts/LandingLayout.astro';
import { getCollection, render } from 'astro:content';

const all = await getCollection('projects');
const get = (id: string) => all.find((p) => p.id === id);

// Every clickable tile / opened view needs its writeup embedded (hidden).
const writeupIds = [
  'exploration', 'keycaps', 'progression', 'table-tennis-bat', // "personal projects" view
  'essay-1', 'essay-2',                                        // "essays" view
  'cv',                                                        // CV button opens this full-page
  // parked for the future "more works" view:
  'living-lamp', 'trebuchet', 'culture', 'creative-skills',
];
const writeups = (
  await Promise.all(
    writeupIds.map(async (id) => {
      const entry = get(id);
      if (!entry) return null;
      const { Content } = await render(entry);
      return { id, entry, Content };
    })
  )
).filter((w): w is NonNullable<typeof w> => w !== null);

const data = (id: string) => {
  const e = get(id);
  return { id, title: e?.data.title ?? id, cover: e?.data.cover, desc: e?.data.description ?? '' };
};

// Cells 0 (contact) and 5 (the nav box) persist across views. Cells 1–4 swap
// between page 1 = "personal projects" and page 2 = "essays", driven by the
// nav-box buttons (see site.ts). Page-2 cells 3/4 are blank until there are
// more essays.
const cells = [
  { p1: { kind: 'name' },                               p2: { kind: 'name' } },
  { p1: { kind: 'photo', ...data('exploration') },      p2: { kind: 'photo', ...data('essay-1') } },
  { p1: { kind: 'photo', ...data('keycaps') },          p2: { kind: 'photo', ...data('essay-2') } },
  { p1: { kind: 'photo', ...data('progression') },      p2: { kind: 'blank' } },
  { p1: { kind: 'photo', ...data('table-tennis-bat') }, p2: { kind: 'blank' } },
  { p1: { kind: 'nav' },                                p2: { kind: 'nav' } },
];

const CONTACT_EMAIL = 'raphael.murraybrowne@gmail.com';
---

<LandingLayout title="Raphael Murray-Browne">
  <div class="stage" data-page="1">
    <ul class="landing-grid">
      {cells.map((cell) => (
        <li class="cell">
          {[cell.p1, cell.p2].map((t, i) => {
            const page = i + 1;
            if (t.kind === 'name') {
              // Not a <button> — it holds real form controls, which can't legally
              // nest inside an interactive element. Persists across views. The
              // name + blurb are click targets (data-focus-message) that jump
              // focus into the message box — see initContactForm. The send button
              // lives INSIDE the message box and doubles as the status display.
              return (
                <div class="tile tile--contact tile--persist" data-page={page}>
                  <div class="contact-card">
                    <div class="contact-head">
                      <h1 class="contact-name" data-focus-message>
                        <span>Raphael</span>
                        <span>Murray</span>
                        <span>Browne</span>
                      </h1>
                      <div class="contact-blurb" data-focus-message>
                        <p>Third year Product and Furniture Design student at University of Plymouth, UK.</p>
                        <p>Come check out my works, and drop me a message below (no details required).</p>
                      </div>
                    </div>
                    <form
                      class="contact-form"
                      data-contact-form
                      action={`https://formsubmit.co/ajax/${CONTACT_EMAIL}`}
                      method="POST"
                    >
                      <input type="hidden" name="_subject" value="New message — raphaelmurraybrowne.com" />
                      <input type="hidden" name="_template" value="basic" />
                      <input
                        class="contact-honey"
                        type="text"
                        name="_honey"
                        tabindex={-1}
                        autocomplete="off"
                        aria-hidden="true"
                      />
                      <input
                        class="contact-email"
                        type="email"
                        name="email"
                        placeholder="Email address (optional)"
                        autocomplete="email"
                      />
                      <div class="contact-message-wrap">
                        <textarea class="contact-message" name="message" placeholder="Message" rows={3} required></textarea>
                        <button class="contact-submit" type="submit" data-state="idle">
                          <span class="contact-submit-label">send</span>
                          <span class="contact-submit-dots" aria-hidden="true"><i></i><i></i><i></i></span>
                        </button>
                      </div>
                    </form>
                  </div>
                </div>
              );
            }
            if (t.kind === 'nav') {
              // The bottom-right cell: a 2×2 of section buttons (persists). Essays
              // / Personal Projects swap the project tiles (page 2 / page 1); CV
              // opens a full-page view; "more works" is wired but inert for now.
              return (
                <div class="tile tile--nav tile--persist" data-page={page}>
                  <button class="nav-box" type="button" data-action="view" data-view="2"><span class="nav-label">essays</span></button>
                  <button class="nav-box" type="button" data-action="view" data-view="1"><span class="nav-label">personal projects</span></button>
                  <button class="nav-box" type="button" data-action="cv"><span class="nav-label">cv</span></button>
                  <button class="nav-box nav-box--more" type="button" data-action="more"><span class="nav-label">more works</span></button>
                </div>
              );
            }
            if (t.kind === 'blank') {
              return <div class="tile tile--blank" data-page={page} aria-hidden="true"></div>;
            }
            // photo tile
            return (
              <button class="tile tile--photo" data-page={page} data-open={t.id} type="button">
                <span class="tile-media">
                  <img class="tile-img" src={t.cover} alt="" loading="lazy" />
                  <span class="tile-overview"><span class="tile-overview-text">{t.desc}</span></span>
                </span>
                <span class="tile-name">{t.title}</span>
              </button>
            );
          })}
        </li>
      ))}
    </ul>

    {/* Hidden writeups, revealed in place when a tile is opened */}
    <div class="writeups">
      {writeups.map((w) => {
        const Body = w.Content;
        return (
          <article class="writeup" data-for={w.id} hidden>
            <p class="project-desc">{w.entry.data.description}</p>
            <div class="project-body"><Body /></div>
          </article>
        );
      })}
    </div>
  </div>

  {/* Dev-only tuner — present under `npm run dev`, stripped from production builds. */}
  {import.meta.env.DEV && (
    <div class="dev-tuner" data-dev-tuner>
      <label>bio ¶1 nudge
        <input type="range" id="bio-p1-y" min="-40" max="160" step="1" value="5" />
      </label>
      <output id="bio-p1-y-out">5px</output>
    </div>
  )}
</LandingLayout>
