---
import { getCollection, render } from 'astro:content';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const projects = await Promise.all(
  sorted.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  })
);

const MARQUEE_COPIES = 4;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Portfolio of Raphael Murray-Browne — product designer." />
  <title>Raphael Murray-Browne</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="stylesheet" href="https://use.typekit.net/var1bvf.css" />
</head>
<body>

<div class="layout">

  <!-- Col 1: title list -->
  <nav class="title-col">
    <div class="item" data-item="about">
      <button class="item-trigger" type="button" aria-expanded="false">
        <span class="item-name">About</span>
      </button>
    </div>
    <div class="item" data-item="contact">
      <button class="item-trigger" type="button" aria-expanded="false">
        <span class="item-name">Contact</span>
      </button>
    </div>
    {projects.map(({ entry }) => (
      <div class="item" data-item={entry.id}>
        <button class="item-trigger" type="button" aria-expanded="false">
          <span class="item-name">{entry.data.title}</span>
        </button>
      </div>
    ))}
  </nav>

  <!-- Col 2: text — col 3 images are injected here by JS and overlap right edge -->
  <div class="content-col">

    <div class="item-panel" data-panel="about">
      <div class="prose-area">
        <p>Aspiring product designer; do you think I'm there yet?</p>
        <p>First-year work exploring electronics, materials, manufacturing, and the relationship between objects and the people who use them.</p>
      </div>
    </div>

    <div class="item-panel" data-panel="contact">
      <div class="prose-area">
        <a class="contact-link" href="mailto:raphael.murraybrowne@gmail.com">raphael.murraybrowne@gmail.com</a>
        <a class="contact-link" href="https://www.instagram.com/rmb_is_designing/" target="_blank" rel="noopener">↗ Instagram — RMB_IS_DESIGNING</a>
      </div>
    </div>

    {projects.map(({ entry, Content }) => (
      <div class="item-panel" data-panel={entry.id}>
        <div class="project-report">
          <p class="project-desc">{entry.data.description}</p>
          <div class="project-body">
            <Content />
          </div>
        </div>
      </div>
    ))}

  </div>

</div>

<!-- Col 4: fixed vertical marquee — no background, col 3 images layer above it -->
<aside class="marquee-vert" aria-hidden="true">
  <div class="marquee-track">
    {Array.from({ length: MARQUEE_COPIES }).map(() => (
      <span class="marquee-item">RAPHAEL MURRAY BROWNE</span>
    ))}
  </div>
</aside>

<!-- Lightbox -->
<div class="lightbox-overlay" id="lightbox" hidden aria-modal="true" role="dialog">
  <img class="lightbox-img" src="" alt="" />
</div>

<!-- ── TEST CONTROLS (remove when done) ──────────────────────── -->
<div id="test-controls">
  <label style="flex-direction:row;align-items:center;gap:0.3rem;">
    nav font<input type="text" id="pick-nav-font" placeholder="cofo-sans-pixel"
      style="width:11rem;font-family:monospace;font-size:0.6rem;padding:0.2rem 0.3rem;border:1px solid #ccc;">
  </label>
  <label style="flex-direction:row;align-items:center;gap:0.3rem;">
    body font<input type="text" id="pick-body-font" placeholder="cofo-sans-pixel"
      style="width:11rem;font-family:monospace;font-size:0.6rem;padding:0.2rem 0.3rem;border:1px solid #ccc;">
  </label>
  <label style="flex-direction:row;align-items:center;gap:0.3rem;">
    drop cap font<input type="text" id="pick-dropcap-font" placeholder="cofo-sans-pixel"
      style="width:11rem;font-family:monospace;font-size:0.6rem;padding:0.2rem 0.3rem;border:1px solid #ccc;">
  </label>
  <label style="flex-direction:row;align-items:center;gap:0.3rem;">
    marquee font<input type="text" id="pick-marquee-font" placeholder="bitcount-mono-single-square"
      style="width:11rem;font-family:monospace;font-size:0.6rem;padding:0.2rem 0.3rem;border:1px solid #ccc;">
  </label>
</div>

</body>
</html>

<style is:global>
  :root {
    --fg:     #1c1c1c;
    --accent: #5200ff;
    --bg:     #fafafa;
    --nav-font:     'cofo-sans-pixel', sans-serif;
    --body-font:    'argent-pixel-cf', sans-serif;
    --dropcap-font: 'lores-9-plus-narrow', sans-serif;
    --marquee-font: 'bitcount-mono-single-square', sans-serif;
    --col-w:  14rem;

    /* Testable tokens */
    --col1-bg:        #eebe11;
    --col1-color:     #fafafa;
    --col1-hover:     #0913ff;
    --col2-bg:        #fafafa;
    --body-color:     #f80d0d;
    --title-color:    #f80d0d;
    --marquee-color:  #eebe12;
    --marquee-hover:  #0913ff;
    --col4-bg:        #fafafa;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html, body {
    height: 100%;
    background: var(--bg);
    color: var(--fg);
    -webkit-font-smoothing: antialiased;
  }

  /* ── Layout shell ───────────────────────────────── */
  .layout {
    display: flex;
    height: 100dvh;
    overflow: hidden;
    /* --right-gap (slider) = desired gap from body text to marquee letters.
       Marquee text is 11.2rem wide in a 14rem column → 2.8rem dead zone on left.
       padding-right = (col-w − 2.8rem) + right-gap so that
         right-gap = 0  → text flush with marquee letters
         right-gap = 45px ≈ 2.8rem → text at marquee column edge
       Content-col z-index 15 safely overlaps the marquee dead zone. */
    padding-right: calc(var(--col-w) - 2.8rem - 12px);
  }

  /* ── Col 1: titles ──────────────────────────────── */
  .title-col {
    flex-shrink: 0;
    height: 100%;
    overflow-y: auto;
    scrollbar-width: none;
    padding-top: 1rem;
    padding-bottom: 6rem;
    background: var(--col1-bg);
  }
  .title-col::-webkit-scrollbar { display: none; }

  /* ── Col 2 (+ col 3): content ───────────────────── */
  .content-col {
    flex: 1;
    min-width: 0;
    height: 100%;
    overflow-y: auto;
    scrollbar-width: none;
    padding-top: 1rem;
    padding-bottom: 6rem;
    background: var(--col2-bg);
    position: relative;
    z-index: 15;
  }
  .content-col::-webkit-scrollbar { display: none; }

  /* ── Panel visibility ───────────────────────────── */
  .item-panel { display: none; }
  .item-panel[data-open] { display: block; }

  /* ── Title triggers ─────────────────────────────── */
  .item-trigger {
    display: inline-flex;
    align-items: center;
    padding: 0.55rem calc(clamp(1rem, 4vw, 2.5rem) + 0.35rem) 0.55rem clamp(1rem, 4vw, 2.5rem);
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: var(--nav-font);
    color: var(--col1-color);
  }
  .item-name {
    font-family: var(--nav-font);
    font-weight: 700;
    font-style: normal;
    font-size: clamp(1.1rem, 2.2vw, 1.6rem);
    line-height: 1.1;
    color: inherit;
    text-transform: lowercase;
    transition: color 0.18s ease;
  }
  .item-trigger:hover .item-name,
  .item[data-open] > .item-trigger .item-name {
    color: var(--col1-hover);
    font-style: italic;
  }

  /* ── Word-split ─────────────────────────────────── */
  .word-wrap { display: inline-block; position: relative; vertical-align: top; }
  .word-half { display: block; transition: transform 0.22s cubic-bezier(0.77,0,0.175,1); will-change: transform; }
  .word-top  { clip-path: inset(0 0 42% 0); }
  .word-bot  { position: absolute; top:0; left:0; width:100%; clip-path: inset(58% 0 0 0); }
  .item[data-open] .word-top { transform: translateX(2px); }
  .item[data-open] .word-bot { transform: translateX(-2px); }

  /* ── About / Contact prose ──────────────────────── */
  .prose-area {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 0.75rem clamp(1rem, 4vw, 2.5rem) 1.5rem;
    max-width: 56ch;
  }
  .prose-area p { font-family: var(--body-font); font-size: 0.9rem; font-weight: 400; line-height: 1.75; }
  .contact-link {
    display: block; font-family: var(--body-font); font-size: 0.9rem;
    color: var(--fg); text-decoration: none; width: fit-content;
    border-bottom: 1px solid transparent; transition: color 0.15s, border-color 0.15s;
  }
  .contact-link:hover { color: var(--accent); border-bottom-color: var(--accent); }

  /* ── Project report container ───────────────────── */
  .project-report {
    padding: 0.75rem 0.4rem 2rem clamp(1rem, 4vw, 2.5rem);
  }

  /* ── Project desc ───────────────────────────────── */
  .project-desc {
    font-family: var(--body-font);
    font-weight: 700;
    font-size: 0.9rem;
    line-height: 1.7;
    color: var(--fg);
    margin-bottom: 1rem;
  }

  /* ── Project body ───────────────────────────────── */
  .project-body {
    font-family: var(--body-font);
    font-size: 1rem;
    font-weight: 400;
    line-height: 1.75;
    letter-spacing: -0.01em;
    color: var(--body-color);
  }
  .project-body p            { margin-bottom: 0.9rem; }
  .project-body p:last-child { margin-bottom: 0; }
  .project-body h2 {
    font-family: var(--body-font);
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    color: var(--title-color);
    margin-top: 1.8rem;
    margin-bottom: 0.5rem;
  }
  .project-body h3 {
    font-family: var(--body-font);
    font-weight: 700;
    font-size: 0.65rem;
    text-transform: uppercase;
    color: var(--title-color);
    margin-top: 1rem;
    margin-bottom: 0.3rem;
  }
  .project-body ul,
  .project-body ol   { padding-left: 1.1rem; margin-bottom: 0.9rem; }
  .project-body li   { margin-bottom: 0.2rem; }
  .project-body a    { color: var(--accent); text-decoration: underline; }
  .project-body strong { font-weight: 700; }
  .project-body em   { font-style: italic; }
  .project-body img  { max-width: 100%; height: auto; display: block; margin: 1.5rem 0; cursor: zoom-in; }

  /* ── Hero pair: 2-up landscape (3:2) ───────────────
     Use <div class="hero-pair"> for two side-by-side
     hero images above the body text. */
  .hero-pair {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.4rem;
    margin-bottom: 1.5rem;
  }
  .hero-pair img {
    aspect-ratio: 3 / 2;
    object-fit: cover;
    width: 100%;
    margin: 0;
    display: block;
    cursor: zoom-in;
  }

  /* ── Image grid: 3-column square-crop ───────────────
     Use <div class="img-grid"> in markdown to get a
     responsive 3-up grid with object-fit cover crops. */
  .img-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0.4rem;
    margin: 1.5rem 0;
    clear: both;
  }
  .img-grid img {
    aspect-ratio: 1 / 1;
    object-fit: cover;
    width: 100%;
    margin: 0;
    display: block;
    cursor: zoom-in;
  }

  /* ── Keycaps: enlarged body + drop-cap headers ─────────────
     Scoped to [data-panel="keycaps"] while experimenting.
     Drop-cap maths:
       body line height  2rem × 1.2 = 2.4rem
       body half-leading (2rem × 0.2) / 2 = 0.2rem above chars
       h2 line-height: 1 → 0 half-leading; margin-top: 0.2rem aligns char tops
       float footprint   0.2rem + 4rem = 4.2rem
       line 2 top 2.4rem < 4.2rem → wraps ✓
       line 3 top 4.8rem > 4.2rem → full width ✓  */
  [data-panel="keycaps"] .project-report {
    padding: 0.55rem 0.4rem 1.5rem clamp(0.75rem, 3vw, 1.875rem);
  }
  [data-panel="keycaps"] .project-desc {
    font-size: 2rem;        /* normal body size; stays black */
    line-height: 1.4;
    margin-bottom: 1.5rem;
  }
  [data-panel="keycaps"] .project-body {
    font-size: 2rem;
    line-height: 1.2;
  }
  [data-panel="keycaps"] .project-body p {
    text-align: justify;
    hyphens: auto;
  }
  [data-panel="keycaps"] .project-body::after {
    content: '';
    display: table;
    clear: both;
  }
  [data-panel="keycaps"] .project-body h2 {
    float: left;
    clear: both;            /* each header clears the previous section's float */
    font-size: 4rem;
    line-height: 1;         /* no half-leading → h2 text starts at top of box  */
    font-family: var(--dropcap-font);
    font-weight: 700;
    font-style: normal;
    color: var(--title-color);
    text-transform: uppercase;
    /* margin-top = body half-leading = (2rem × (1.2−1)) / 2 = 0.2rem
       → aligns h2 character tops with body line-1 character tops
       Float footprint = 0.2 + 4rem = 4.2rem → exactly 2 body lines wrap:
         line 2 top (2.4rem) < 4.2rem ✓   line 3 top (4.8rem) > 4.2rem ✓  */
    margin: 0.2rem 0.75rem 0 0;
  }

  /* ── Lightbox ───────────────────────────────────── */
  .lightbox-overlay {
    position: fixed; inset: 0;
    background: rgba(0,0,0,0.90);
    z-index: 200;
    display: flex; align-items: center; justify-content: center;
    cursor: zoom-out;
  }
  .lightbox-overlay[hidden] { display: none; }
  .lightbox-overlay.lb-open { animation: lb-in 0.18s ease both; }
  .lightbox-overlay.lb-out  { animation: lb-out 0.15s ease both; }
  .lightbox-img {
    max-width: min(90vw, 1200px); max-height: 90dvh;
    object-fit: contain; display: block; pointer-events: none;
    box-shadow: 0 8px 48px rgba(0,0,0,0.5);
  }
  @keyframes lb-in  { from { opacity:0; transform:scale(0.97); } to { opacity:1; transform:scale(1); } }
  @keyframes lb-out { from { opacity:1; transform:scale(1); }   to { opacity:0; transform:scale(0.97); } }

  /* ── Col 4: marquee ─────────────────────────────── */
  .marquee-vert {
    position: fixed; top: 0; right: 0;
    width: var(--col-w); height: 100dvh;
    overflow: hidden; z-index: 10;
    background: var(--col4-bg);
  }
  .marquee-track {
    display: flex; flex-direction: column; align-items: flex-end;
    width: 100%;
    animation: march-down 140s linear 1s infinite;
    animation-fill-mode: backwards;
    will-change: transform;
  }
  .marquee-vert { cursor: pointer; }
  .marquee-item {
    writing-mode: vertical-rl; transform: rotate(180deg);
    font-family: var(--marquee-font); font-weight: 400;
    font-size: 11.2rem;
    line-height: 1; text-transform: uppercase; color: var(--marquee-color);
    padding-inline: 6rem; white-space: nowrap; user-select: none;
    transition: color 0.3s ease;
  }
  .marquee-vert:hover .marquee-item { color: var(--marquee-hover); }

  /* ── Marquee start position fix ─────────────────────
     rotate(180deg) puts R at the visual BOTTOM of each copy's bounding box.
     +100dvh shifts so the copy CSS-bottom aligns with the viewport bottom.
     +3rem corrects for padding-inline-end (below R in visual space).
     Loop: -25% = copy1 bottom → same visual frame → seamless.
     0% keyframe timing: ease-in for first 2% (~2.8s) → soft start. */
  @keyframes march-down {
    0% {
      transform: translateY(calc(-75% + 100dvh + 3rem));
      animation-timing-function: cubic-bezier(0.1, 0, 0.5, 0.5);
    }
    2% {
      /* -75% + (2% × 50% range) = -74%. Explicit value required so the
         timing-function switch takes effect; without it, ease-in applies
         to the full 140 s. Bezier chosen so end-speed = 1× linear — no jerk. */
      transform: translateY(calc(-74% + 100dvh + 3rem));
      animation-timing-function: linear;
    }
    100% { transform: translateY(calc(-25% + 100dvh + 3rem)); }
  }

  /* ── Test controls ──────────────────────────────── */
  #test-controls {
    position: fixed;
    bottom: 1rem;
    /* Sits just inside the content column area */
    left: calc(var(--accent, 14rem) + 1rem);
    left: 14rem; /* fallback: just past where title col ends */
    z-index: 100;
    display: flex;
    gap: 0.75rem;
    padding: 0.4rem 0.6rem;
    background: rgba(240,240,240,0.95);
    font-family: monospace;
    font-size: 0.65rem;
  }
  #test-controls label {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.2rem;
  }
  #test-controls input[type="color"] {
    width: 2rem;
    height: 1.4rem;
    padding: 0;
    border: 1px solid #ccc;
    cursor: pointer;
  }
</style>

<script>
  // ── Typing animation ───────────────────────────────────────────────────
  let typingTimer: ReturnType<typeof setInterval> | null = null;

  function cancelTyping() {
    if (typingTimer !== null) { clearInterval(typingTimer); typingTimer = null; }
  }

  function typeInPanel(panel: Element) {
    cancelTyping();

    // Restore original HTML on re-open so animation replays fresh
    const p = panel as HTMLElement;
    if (p.dataset.origHtml !== undefined) {
      p.innerHTML = p.dataset.origHtml;
    } else {
      p.dataset.origHtml = p.innerHTML;
    }

    // Walk every text node and replace each character with a hidden <span>
    const chars: HTMLElement[] = [];
    function walk(node: Node) {
      if (node.nodeType === Node.TEXT_NODE) {
        const text = node.textContent ?? '';
        if (!text) return;
        const frag = document.createDocumentFragment();
        for (const ch of text) {
          const span = document.createElement('span');
          span.textContent = ch;
          span.style.opacity = '0';
          chars.push(span);
          frag.appendChild(span);
        }
        node.parentNode?.replaceChild(frag, node);
      } else if (node.nodeType === Node.ELEMENT_NODE) {
        // Skip image containers — wrapping whitespace text nodes in spans
        // creates extra grid items that break layout.
        const cls = (node as Element).classList;
        if (cls?.contains('img-grid') || cls?.contains('hero-pair')) return;
        Array.from(node.childNodes).forEach(walk);
      }
    }
    walk(panel);

    let idx = 0;
    const CHUNK = 40; // chars revealed per tick (~60fps → ~2400 chars/s)
    const TICK  = 16; // ms
    typingTimer = setInterval(() => {
      for (let i = 0; i < CHUNK && idx < chars.length; i++, idx++) {
        chars[idx].style.opacity = '1';
      }
      if (idx >= chars.length) { clearInterval(typingTimer!); typingTimer = null; }
    }, TICK);
  }

  // ── Word-split animation ───────────────────────────────────────────────
  function buildSplitWords(nameEl) {
    const text = nameEl.textContent?.trim() ?? '';
    nameEl.textContent = '';
    text.split(' ').forEach((word, i, arr) => {
      const wrap = document.createElement('span');
      wrap.className = 'word-wrap';
      const top = document.createElement('span');
      top.className = 'word-half word-top';
      top.textContent = word;
      const bot = document.createElement('span');
      bot.className = 'word-half word-bot';
      bot.textContent = word;
      bot.setAttribute('aria-hidden', 'true');
      wrap.appendChild(top);
      wrap.appendChild(bot);
      nameEl.appendChild(wrap);
      if (i < arr.length - 1) nameEl.appendChild(document.createTextNode(' '));
    });
  }

  // ── Panel toggle ───────────────────────────────────────────────────────
  const allItems   = Array.from(document.querySelectorAll('.item'));
  const allPanels  = Array.from(document.querySelectorAll('.item-panel'));
  const contentCol = document.querySelector('.content-col');

  function toggle(item) {
    const id      = item.dataset.item;
    const wasOpen = item.hasAttribute('data-open');

    allItems.forEach(i => {
      i.removeAttribute('data-open');
      i.querySelector('.item-trigger')?.setAttribute('aria-expanded', 'false');
    });
    allPanels.forEach(p => p.removeAttribute('data-open'));

    if (!wasOpen) {
      item.setAttribute('data-open', '');
      item.querySelector('.item-trigger')?.setAttribute('aria-expanded', 'true');
      const panel = document.querySelector(`[data-panel="${id}"]`);
      if (panel) {
        panel.setAttribute('data-open', '');
        contentCol?.scrollTo({ top: 0 });
        typeInPanel(panel);
      }
    }
  }

  // ── Lightbox ───────────────────────────────────────────────────────────
  const lightbox    = document.getElementById('lightbox');
  const lightboxImg = lightbox?.querySelector('.lightbox-img');

  function openLightbox(img) {
    if (!lightbox || !lightboxImg) return;
    lightboxImg.src = img.src;
    lightboxImg.alt = img.alt;
    lightbox.removeAttribute('hidden');
    lightbox.classList.remove('lb-out');
    lightbox.classList.add('lb-open');
    document.body.style.overflow = 'hidden';
  }

  function closeLightbox() {
    if (!lightbox) return;
    lightbox.classList.remove('lb-open');
    lightbox.classList.add('lb-out');
    lightbox.addEventListener('animationend', () => {
      lightbox.setAttribute('hidden', '');
      lightbox.classList.remove('lb-out');
      document.body.style.overflow = '';
    }, { once: true });
  }

  document.addEventListener('click', e => {
    const el = e.target as Element;
    if (el.tagName === 'IMG' && el.closest('.project-body')) {
      openLightbox(el as HTMLImageElement); return;
    }
    if (e.target === lightbox || lightbox?.contains(e.target as Node)) closeLightbox();
  });
  document.addEventListener('keydown', e => {
    if (e.key === 'Escape' && !lightbox?.hasAttribute('hidden')) closeLightbox();
  });

  // ── Marquee hover ──────────────────────────────────────────────────────
  const marqueeVert  = document.querySelector('.marquee-vert');
  const marqueeTrack = document.querySelector('.marquee-track');

  if (marqueeVert && marqueeTrack) {
    marqueeVert.addEventListener('mouseenter', () => {
      const currentY = new DOMMatrix(window.getComputedStyle(marqueeTrack).transform).m42;
      marqueeTrack.style.animation = 'none';
      marqueeTrack.style.transform = `translateY(${currentY}px)`;
      void marqueeTrack.offsetHeight;
      // Snap to R at bottom of viewport (+3rem corrects for padding-inline below R)
      const rem    = parseFloat(getComputedStyle(document.documentElement).fontSize);
      const startY = -(marqueeTrack.scrollHeight * 0.75) + window.innerHeight + 3 * rem;
      marqueeTrack.style.transition = 'transform 1s cubic-bezier(0.25,0.46,0.45,0.94)';
      marqueeTrack.style.transform  = `translateY(${startY}px)`;
    });

    marqueeVert.addEventListener('mouseleave', () => {
      const currentY = new DOMMatrix(window.getComputedStyle(marqueeTrack).transform).m42;
      const totalH   = marqueeTrack.scrollHeight;
      const vh       = window.innerHeight;
      // Animation: from (-75%*totalH + vh + 3rem) to (-25%*totalH + vh + 3rem)
      const rem      = parseFloat(getComputedStyle(document.documentElement).fontSize);
      const fromY    = -(totalH * 0.75) + vh + 3 * rem;
      const rangeH   =   totalH * 0.5;
      const elapsed  = (currentY - fromY) / rangeH * 140;
      const delay    = -((elapsed % 140 + 140) % 140);
      marqueeTrack.style.transition = 'none';
      marqueeTrack.style.transform  = `translateY(${currentY}px)`;
      void marqueeTrack.offsetHeight;
      marqueeTrack.style.animation  = `march-down 140s linear ${delay.toFixed(3)}s infinite`;
      void marqueeTrack.offsetHeight;
      marqueeTrack.style.transform  = '';
    });

    marqueeVert.addEventListener('click', () => {
      const aboutItem = document.querySelector('.item[data-item="about"]') as HTMLElement | null;
      if (aboutItem) toggle(aboutItem);
    });
  }

  // ── Font pickers (type any installed system font name, press Enter) ────
  const root = document.documentElement;
  function applyFont(inputId: string, prop: string) {
    const el = document.getElementById(inputId) as HTMLInputElement | null;
    if (!el) return;
    const apply = () => {
      const val = el.value.trim();
      if (val) root.style.setProperty(prop, `'${val}', sans-serif`);
    };
    el.addEventListener('change', apply);
    el.addEventListener('keydown', (e) => { if (e.key === 'Enter') apply(); });
  }
  applyFont('pick-nav-font',     '--nav-font');
  applyFont('pick-body-font',    '--body-font');
  applyFont('pick-dropcap-font', '--dropcap-font');
  applyFont('pick-marquee-font', '--marquee-font');


  // ── Init ──────────────────────────────────────────────────────────────
  allItems.forEach(item => {
    const btn    = item.querySelector('.item-trigger');
    const nameEl = item.querySelector('.item-name');
    if (!btn || !nameEl) return;
    buildSplitWords(nameEl);
    btn.addEventListener('click', () => toggle(item));
  });
</script>
