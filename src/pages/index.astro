---
import { getCollection, render } from 'astro:content';

const allProjects = await getCollection('projects');
const sorted = allProjects.sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99));

const projects = await Promise.all(
  sorted.map(async (entry) => {
    const { Content } = await render(entry);
    return { entry, Content };
  })
);

// 4 copies = 2 visible + 2 looping behind → seamless
const MARQUEE_COPIES = 4;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="Portfolio of Raphael Murray-Browne." />
  <title>Raphael Murray-Browne</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Mono:wght@700&family=Noto+Sans:wght@300;400;700&display=swap" rel="stylesheet" />
</head>
<body>

  <main class="list">

    <!-- About -->
    <div class="item">
      <button class="item-trigger" type="button" aria-expanded="false">
        <span class="item-name">About</span>
      </button>
      <div class="item-body-wrap">
        <div class="item-body-inner">
          <div class="prose-area">
            <p>[Your bio here. 2–3 sentences about who you are and what you make.]</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Contact -->
    <div class="item">
      <button class="item-trigger" type="button" aria-expanded="false">
        <span class="item-name">Contact</span>
      </button>
      <div class="item-body-wrap">
        <div class="item-body-inner">
          <div class="prose-area">
            <a class="contact-link" href="mailto:your@email.com">your@email.com</a>
            <a class="contact-link" href="#" target="_blank" rel="noopener">↗ LinkedIn</a>
            <a class="contact-link" href="#" target="_blank" rel="noopener">↗ Instagram</a>
          </div>
        </div>
      </div>
    </div>

    <!-- Projects -->
    {projects.map(({ entry, Content }) => (
      <div class="item">
        <button class="item-trigger" type="button" aria-expanded="false">
          <span class="item-name">{entry.data.title}</span>
        </button>
        <div class="item-body-wrap">
          <div class="item-body-inner">
            <div class="h-scroll">
              {entry.data.image && (
                <div class="h-block h-block--img">
                  <img src={entry.data.image} alt={entry.data.title} loading="lazy" />
                </div>
              )}
              <div class="h-block h-block--text">
                <p class="project-desc">{entry.data.description}</p>
                <div class="project-body">
                  <Content />
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    ))}

  </main>

  <!-- Fixed vertical marquee — right side -->
  <aside class="marquee-vert" aria-hidden="true">
    <div class="marquee-track">
      {Array.from({ length: MARQUEE_COPIES }).map(() => (
        <span class="marquee-item">RAPHAEL MURRAY BROWNE</span>
      ))}
    </div>
  </aside>

</body>
</html>

<style is:global>
  :root {
    --fg:     #1c1c1c;
    --accent: #5200ff;
    --bg:     #ffffff;
    --mono:   'Space Mono', monospace;
    --sans:   'Noto Sans', system-ui, sans-serif;
    /* marquee column width — matches font-size so the text fills the column */
    --col-w:  14rem;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  html {
    background: var(--bg);
    color: var(--fg);
    -webkit-font-smoothing: antialiased;
  }

  /* ── Main list ───────────────────────────── */
  .list {
    padding-right: var(--col-w);
    padding-top: 1rem;
    padding-bottom: 6rem;
  }

  /* ── Accordion item ──────────────────────── */
  /* No border, no dividers — pure whitespace separation */
  .item { }

  /* ── Trigger row ─────────────────────────── */
  .item-trigger {
    width: 100%;
    display: flex;
    align-items: center;
    padding: 0.6rem clamp(1rem, 4vw, 2.5rem);
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    font-family: var(--mono);
    color: var(--fg);
  }

  /* ── Item name ───────────────────────────── */
  .item-name {
    font-family: var(--mono);
    font-weight: 700;
    font-size: clamp(1.1rem, 2.2vw, 1.6rem);
    letter-spacing: -0.01em;
    line-height: 1;
  }

  /* Individual letter spans — NO transition, instant colour pop */
  .item-name .letter {
    display: inline-block;
    color: var(--fg);
  }
  .item-name .letter.lit { color: var(--accent); }

  /* ── Accordion body ──────────────────────── */
  .item-body-wrap {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.38s cubic-bezier(0.4, 0, 0.2, 1);
  }
  .item[data-open] .item-body-wrap { grid-template-rows: 1fr; }
  .item-body-inner { overflow: hidden; }

  /* ── About / Contact prose ───────────────── */
  .prose-area {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    padding: 1rem clamp(1rem, 4vw, 2.5rem) 1.75rem;
    max-width: 56ch;
  }
  .prose-area p {
    font-family: var(--sans);
    font-size: 0.9rem;
    font-weight: 400;
    line-height: 1.75;
    color: var(--fg);
  }
  .contact-link {
    display: block;
    font-family: var(--sans);
    font-size: 0.9rem;
    color: var(--fg);
    text-decoration: none;
    width: fit-content;
    border-bottom: 1px solid transparent;
    transition: color 0.15s, border-color 0.15s;
  }
  .contact-link:hover {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }

  /* ── Horizontal scroll area (projects) ───── */
  .h-scroll {
    display: flex;
    gap: 0;
    overflow-x: auto;
    overflow-y: hidden;
    padding: 1.25rem 0 1.75rem;
    align-items: flex-start;
    cursor: grab;
    scrollbar-width: none; /* hide scrollbar — drag to scroll */
  }
  .h-scroll::-webkit-scrollbar { display: none; }
  .h-scroll:active { cursor: grabbing; }

  .h-block { flex-shrink: 0; }

  .h-block--img img {
    display: block;
    height: min(52vh, 460px);
    width: auto;
    max-width: 70vw;
    object-fit: contain;
    padding: 0 clamp(1rem, 4vw, 2.5rem);
  }

  /* Each text card is a fixed-width column */
  .h-block--text {
    width: clamp(280px, 35vw, 440px);
    padding: 0 clamp(1rem, 4vw, 2.5rem);
    border-right: 1px solid #e8e8e8;
  }
  .h-block--text:last-child { border-right: none; }

  .project-desc {
    font-family: var(--sans);
    font-weight: 700;
    font-size: 0.82rem;
    line-height: 1.6;
    margin-bottom: 1.1rem;
    color: var(--fg);
  }

  .project-body {
    font-family: var(--sans);
    font-size: 0.78rem;
    font-weight: 400;
    line-height: 1.9;
    color: #555;
  }
  .project-body p { margin-bottom: 0.8rem; }
  .project-body p:last-child { margin-bottom: 0; }
  .project-body h2 {
    font-family: var(--sans);
    font-weight: 700;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #aaa;
    margin-top: 1.25rem;
    margin-bottom: 0.4rem;
  }
  .project-body h3 {
    font-family: var(--sans);
    font-weight: 700;
    font-size: 0.6rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #aaa;
    margin-top: 1rem;
    margin-bottom: 0.3rem;
  }
  .project-body ul, .project-body ol {
    padding-left: 1.1rem;
    margin-bottom: 0.8rem;
  }
  .project-body li { margin-bottom: 0.15rem; }
  .project-body a { color: var(--accent); text-decoration: underline; }
  .project-body strong { color: var(--fg); }
  .project-body em { font-style: italic; }

  /* ── Vertical marquee ────────────────────── */
  .marquee-vert {
    position: fixed;
    top: 0;
    right: 0;
    width: var(--col-w);
    height: 100dvh;
    overflow: hidden;
    pointer-events: none;
    z-index: 10;
    /* No border */
  }

  .marquee-track {
    display: flex;
    flex-direction: column;
    align-items: center;
    animation: march-up 200s linear infinite;
    will-change: transform;
  }

  .marquee-item {
    writing-mode: vertical-lr;
    transform: rotate(180deg);
    font-family: var(--sans);
    font-weight: 700;
    font-size: 14rem;
    line-height: 1;
    text-transform: uppercase;
    color: var(--fg);         /* off-black, same as body text */
    padding-block: 4rem;
    white-space: nowrap;
    user-select: none;
  }

  @keyframes march-up {
    from { transform: translateY(0); }
    to   { transform: translateY(-50%); }
  }
</style>

<script>
  // ── Split letter spans into the item name ────────────────────────────
  function wrapLetters(el) {
    const raw = el.textContent ?? '';
    el.innerHTML = [...raw].map(ch =>
      ch === ' ' ? ' ' : `<span class="letter">${ch}</span>`
    ).join('');
  }

  // ── Continuous wave while hovering (one lit letter chases left→right) ─
  function startWave(nameEl) {
    stopWave(nameEl); // clear any existing
    const letters = nameEl.querySelectorAll('.letter');
    if (!letters.length) return;
    const GAP = 110; // ms per letter — slower than before
    let i = 0, prev = null;
    function tick() {
      if (prev) prev.classList.remove('lit');
      letters[i].classList.add('lit');
      prev = letters[i];
      i = (i + 1) % letters.length;
      nameEl._waveTimer = setTimeout(tick, GAP);
    }
    tick();
  }

  function stopWave(nameEl) {
    clearTimeout(nameEl._waveTimer);
    nameEl.querySelectorAll('.letter.lit').forEach(l => l.classList.remove('lit'));
  }

  // ── One accordion open at a time ─────────────────────────────────────
  const allItems = Array.from(document.querySelectorAll('.item'));

  function toggle(item) {
    const wasOpen = item.hasAttribute('data-open');

    // Close everything
    allItems.forEach(other => {
      other.removeAttribute('data-open');
      other.querySelector('.item-trigger')?.setAttribute('aria-expanded', 'false');
    });

    // Open this one only if it was previously closed
    if (!wasOpen) {
      item.setAttribute('data-open', '');
      item.querySelector('.item-trigger')?.setAttribute('aria-expanded', 'true');
    }
  }

  // ── Split project body into horizontal cards by h2 heading ───────────
  function splitIntoCards(hscroll) {
    const textBlock = hscroll.querySelector('.h-block--text');
    if (!textBlock) return;
    const body = textBlock.querySelector('.project-body');
    if (!body) return;

    const children = Array.from(body.children);
    const sections = [];
    let current = [];

    children.forEach(el => {
      if (el.tagName === 'H2' && current.length > 0) {
        sections.push([...current]);
        current = [el];
      } else {
        current.push(el);
      }
    });
    if (current.length) sections.push(current);
    if (sections.length <= 1) return; // Nothing to split

    // Replace body contents with first section
    while (body.firstChild) body.removeChild(body.firstChild);
    sections[0].forEach(el => body.appendChild(el));

    // Append remaining sections as new sibling h-blocks
    for (let i = 1; i < sections.length; i++) {
      const block = document.createElement('div');
      block.className = 'h-block h-block--text';
      const newBody = document.createElement('div');
      newBody.className = 'project-body';
      sections[i].forEach(el => newBody.appendChild(el));
      block.appendChild(newBody);
      hscroll.appendChild(block);
    }
  }

  // ── Drag-to-scroll on horizontal areas ───────────────────────────────
  function addDragScroll(el) {
    let down = false, startX = 0, scrollL = 0;
    el.addEventListener('mousedown', e => {
      down = true; startX = e.pageX - el.offsetLeft; scrollL = el.scrollLeft;
    });
    el.addEventListener('mouseleave', () => { down = false; });
    el.addEventListener('mouseup',    () => { down = false; });
    el.addEventListener('mousemove',  e => {
      if (!down) return;
      e.preventDefault();
      el.scrollLeft = scrollL - (e.pageX - el.offsetLeft - startX) * 1.4;
    });
  }

  // ── Init ─────────────────────────────────────────────────────────────
  allItems.forEach(item => {
    const btn    = item.querySelector('.item-trigger');
    const nameEl = item.querySelector('.item-name');
    if (!btn || !nameEl) return;

    wrapLetters(nameEl);

    btn.addEventListener('mouseenter', () => startWave(nameEl));
    btn.addEventListener('mouseleave', () => stopWave(nameEl));
    btn.addEventListener('click',      () => toggle(item));
  });

  document.querySelectorAll('.h-scroll').forEach(el => {
    splitIntoCards(el);
    addDragScroll(el);
  });
</script>
