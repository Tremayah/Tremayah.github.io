---
/*  "/<project>/" — one page generated per markdown file in
    src/content/projects/. Add a project by dropping in a new .md file; it gets
    its own page here and its own nav entry in TitleNav automatically. */
import { getCollection, render } from 'astro:content';
import SiteLayout from '../layouts/SiteLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<SiteLayout title={`${entry.data.title} — Raphael Murray-Browne`} description={entry.data.description}>
  <article class="project-report" data-project={entry.id}>
    <p class="project-desc">{entry.data.description}</p>
    <div class="project-body">
      <Content />
    </div>
  </article>
</SiteLayout>
